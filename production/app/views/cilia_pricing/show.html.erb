<%
breadcrumbs = [
  {active: false, href: root_path, text: t('menu.initial_page')},
  {active: false, href: cilia_pricing_index_path, text: 'Precificação Cilia'},
  {active: true, href: '#', text: "OS #{@order_service.code}"},
]

can_edit = policy(:cilia_pricing).update_prices?
can_complete = policy(:cilia_pricing).mark_complete?
%>

<div class="container-fluid">
  <%= render 'common_pages/breadcrumb', links: breadcrumbs %>

  <!-- Cabeçalho da OS -->
  <div class="row mb-3">
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-start">
        <div>
          <h3>
            <i class="bi bi-currency-dollar"></i>
            Precificação Cilia - OS <%= @order_service.code %>
            <% if @order_service.cilia_priced_at.present? %>
              <span class="badge bg-success ms-2">
                <i class="bi bi-check-circle"></i> Precificada
              </span>
            <% end %>
          </h3>
        </div>
        <div class="d-flex gap-2">
          <% if can_complete %>
            <% if @order_service.cilia_priced_at.present? %>
              <%= link_to unmark_complete_cilia_pricing_path(@order_service),
                method: :patch,
                class: 'btn btn-outline-warning btn-sm',
                data: { confirm: 'Deseja desmarcar esta OS como precificada?' } do %>
                <i class="bi bi-arrow-counterclockwise"></i> Desmarcar
              <% end %>
            <% else %>
              <%= link_to mark_complete_cilia_pricing_path(@order_service),
                method: :patch,
                class: 'btn btn-success btn-sm',
                data: { confirm: 'Marcar esta OS como precificada pelo Cilia?' } do %>
                <i class="bi bi-check-circle"></i> Marcar como Precificada
              <% end %>
            <% end %>
          <% end %>
          <%= link_to cilia_pricing_index_path, class: 'btn btn-outline-secondary btn-sm' do %>
            <i class="bi bi-arrow-left"></i> Voltar
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Info da OS -->
  <div class="row mb-3">
    <div class="col-md-6">
      <div class="card">
        <div class="card-header bg-light py-2">
          <strong><i class="bi bi-file-text"></i> Dados da OS</strong>
        </div>
        <div class="card-body py-2">
          <div class="row">
            <div class="col-6">
              <small class="text-muted">Código</small><br>
              <strong><%= @order_service.code %></strong>
            </div>
            <div class="col-6">
              <small class="text-muted">Tipo</small><br>
              <%= @order_service.order_service_type&.name || '-' %>
            </div>
          </div>
          <div class="row mt-2">
            <div class="col-6">
              <small class="text-muted">Status</small><br>
              <%= @order_service.order_service_status&.name || '-' %>
            </div>
            <div class="col-6">
              <small class="text-muted">Criada em</small><br>
              <%= @order_service.created_at.strftime('%d/%m/%Y %H:%M') %>
            </div>
          </div>
          <% if @order_service.cilia_priced_at.present? %>
            <div class="row mt-2">
              <div class="col-12">
                <small class="text-muted">Precificada em</small><br>
                <span class="text-success">
                  <i class="bi bi-check-circle"></i>
                  <%= @order_service.cilia_priced_at.strftime('%d/%m/%Y %H:%M') %>
                  <% if @order_service.cilia_priced_by.present? %>
                    por <%= @order_service.cilia_priced_by.name %>
                  <% end %>
                </span>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card">
        <div class="card-header bg-light py-2">
          <strong><i class="bi bi-truck"></i> Veículo</strong>
        </div>
        <div class="card-body py-2">
          <div class="row">
            <div class="col-6">
              <small class="text-muted">Placa</small><br>
              <strong><%= @vehicle&.board || '-' %></strong>
            </div>
            <div class="col-6">
              <small class="text-muted">Marca / Modelo</small><br>
              <%= @vehicle&.brand %> <%= @vehicle&.model %>
            </div>
          </div>
          <div class="row mt-2">
            <div class="col-6">
              <small class="text-muted">Ano</small><br>
              <%= @vehicle&.year || '-' %>
            </div>
            <div class="col-6">
              <small class="text-muted">Modelo Vinculado</small><br>
              <% if @vehicle_model.present? %>
                <span class="badge bg-info text-dark">
                  <i class="bi bi-link-45deg"></i> <%= @vehicle_model.display_name %>
                </span>
                <% if @vehicle_model.code_cilia.present? %>
                  <br><small class="text-muted">Cód. Cilia: <%= @vehicle_model.code_cilia %></small>
                <% end %>
              <% else %>
                <span class="badge bg-danger">
                  <i class="bi bi-exclamation-triangle"></i> Sem modelo vinculado
                </span>
                <br>
                <small class="text-muted">
                  Vincule o modelo em 
                  <%= link_to 'Veículos', edit_vehicle_path(@vehicle), target: '_blank' if @vehicle %>
                  para salvar preços de referência.
                </small>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Propostas e Itens -->
  <% if @proposals_data.any? %>
    <%= form_tag update_prices_cilia_pricing_path(@order_service), method: :patch do %>
      <% rendered_service_ids = [] %>
      <% @proposals_data.each_with_index do |pd, idx| %>
        <% proposal = pd[:proposal] %>
        <div class="card mb-3">
          <div class="card-header bg-light py-2">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <strong>
                  <i class="bi bi-file-earmark-text"></i>
                  Proposta <%= proposal.code %>
                </strong>
                <% if proposal.provider.present? %>
                  <span class="text-muted ms-2">
                    - Fornecedor: <strong><%= proposal.provider.name %></strong>
                  </span>
                <% end %>
              </div>
              <div>
                <span class="badge <%= pd[:parts_without_reference] > 0 ? 'bg-warning text-dark' : 'bg-success' %>">
                  <%= pd[:parts_with_reference] %>/<%= pd[:total_parts] %> peças com referência
                </span>
              </div>
            </div>
          </div>
          <div class="card-body p-0">
            <% if pd[:parts].any? %>
              <!-- Tabela de Peças -->
              <div class="px-3 pt-2">
                <h6 class="text-muted mb-0">
                  <i class="bi bi-gear"></i> Peças (<%= pd[:parts].size %>)
                </h6>
              </div>
              <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                  <thead class="table-light">
                    <tr>
                      <th>Peça</th>
                      <th>Marca</th>
                      <th class="text-end">Preço Fornecedor</th>
                      <th class="text-end text-muted small" style="width:120px;">
                        Média 3 Cot. anteriores
                        <i class="bi bi-info-circle" data-bs-toggle="tooltip" title="Média das últimas 3 OS aprovadas deste veículo para o mesmo item"></i>
                      </th>
                      <th class="text-end" style="width: 160px;">
                        Ref. Tabela (Cilia)
                        <br><small class="text-muted fw-normal">ou marcar Sem Ref.</small>
                      </th>
                      <th style="width: 130px;">Código de Referência</th>
                      <th class="text-center" style="width: 70px;">% Máx.</th>
                      <th style="width: 130px;">Fonte</th>
                      <th class="text-center" style="width: 90px;">Status</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% pd[:parts].each do |part_data| %>
                      <%
                        item = part_data[:item]
                        ref = part_data[:reference_price]
                        service_id = item.service_id
                        provider_price = item.unity_value.to_f
                        hist_avg = part_data[:historical_avg]
                        hist_count = part_data[:historical_count]
                        hist_prices = part_data[:historical_prices] || []
                        is_sem_tabela = part_data[:sem_tabela]
                        already_rendered = service_id.present? && rendered_service_ids.include?(service_id)
                        rendered_service_ids << service_id if service_id.present? && !already_rendered

                        exceeded = false
                        diff_percent = 0
                        if ref.present? && !is_sem_tabela && ref.reference_price.to_f > 0
                          max_allowed = ref.max_allowed_price
                          if max_allowed
                            exceeded = provider_price > max_allowed
                            diff_percent = (((provider_price - ref.reference_price.to_f) / ref.reference_price.to_f) * 100).round(0)
                          end
                        end
                      %>
                      <tr>
                        <td>
                          <strong><%= item.service_name.presence || item.service&.name || '-' %></strong>
                          <% if item.service&.code.present? %>
                            <br><small class="text-muted">Cód: <%= item.service.code %></small>
                          <% end %>
                        </td>
                        <td><%= item.brand || '-' %></td>
                        <td class="text-end">
                          <strong><%= CustomHelper.to_currency(provider_price) %></strong>
                          <% if item.quantity.to_i > 1 %>
                            <br><small class="text-muted">x<%= item.quantity %> = <%= CustomHelper.to_currency(item.total_value) %></small>
                          <% end %>
                        </td>
                        <%# Coluna histórico / pesquisa de mercado %>
                        <td>
                          <% if is_sem_tabela && hist_count > 0 %>
                            <%
                              hist_diff = provider_price - hist_avg
                              hist_color = hist_diff.abs <= 10 ? 'success' : (hist_diff > 10 ? 'danger' : 'info')
                              hist_arrow = hist_diff > 10 ? '↑' : (hist_diff < -10 ? '↓' : '≈')
                            %>
                            <div class="border border-info rounded p-2 small bg-light">
                              <div class="fw-bold text-info mb-1">
                                <i class="bi bi-search"></i> Pesquisa de Mercado
                              </div>
                              <div>Média: <strong><%= CustomHelper.to_currency(hist_avg) %></strong>
                                <span class="text-<%= hist_color %> ms-1"><%= hist_arrow %></span>
                              </div>
                              <% if hist_prices.any? %>
                                <div class="text-muted mt-1">
                                  Cotações: <%= hist_prices.map { |p| CustomHelper.to_currency(p) }.join(' · ') %>
                                </div>
                              <% end %>
                              <div class="text-muted">(<%= hist_count %> OS anterior<%= hist_count > 1 ? 'es' : '' %>)</div>
                            </div>
                          <% elsif hist_count > 0 %>
                            <%
                              hist_diff = provider_price - hist_avg
                              hist_color = hist_diff.abs <= 10 ? 'success' : (hist_diff > 10 ? 'danger' : 'info')
                              hist_arrow = hist_diff > 10 ? '↑' : (hist_diff < -10 ? '↓' : '≈')
                            %>
                            <div class="text-end">
                              <span class="text-<%= hist_color %> fw-bold" data-bs-toggle="tooltip"
                                title="Média de <%= hist_count %> cotação(ões) anterior(es): <%= CustomHelper.to_currency(hist_avg) %>">
                                <%= hist_arrow %> <%= CustomHelper.to_currency(hist_avg) %>
                              </span>
                              <br><small class="text-muted">(<%= hist_count %> cot.)</small>
                            </div>
                          <% else %>
                            <small class="text-muted">Sem histórico</small>
                          <% end %>
                        </td>
                        <%# Coluna Ref. Tabela %>
                        <td class="text-end">
                          <% if service_id.present? && @vehicle_model.present? && can_edit && !already_rendered %>
                            <%# Botão toggle Sem referência na tabela %>
                            <div class="mb-2">
                              <%= check_box_tag "reference_prices[#{service_id}][sem_tabela]", '1',
                                is_sem_tabela,
                                class: 'btn-check sem-tabela-check',
                                id: "sem_tabela_#{service_id}",
                                autocomplete: 'off',
                                data: { service_id: service_id } %>
                              <label class="btn btn-sm <%= is_sem_tabela ? 'btn-warning' : 'btn-outline-secondary' %>"
                                     for="sem_tabela_<%= service_id %>">
                                <i class="bi bi-slash-circle"></i> Sem ref. tabela
                              </label>
                            </div>
                            <div id="price-input-<%= service_id %>" class="<%= is_sem_tabela ? 'd-none' : '' %>">
                              <div class="input-group input-group-sm">
                                <span class="input-group-text">R$</span>
                                <%= text_field_tag "reference_prices[#{service_id}][reference_price]",
                                  (!is_sem_tabela && ref.present?) ? number_with_precision(ref.reference_price, precision: 2) : nil,
                                  class: "form-control form-control-sm text-end cilia-price-input",
                                  placeholder: '0,00',
                                  data: { provider_price: provider_price } %>
                              </div>
                            </div>
                          <% elsif already_rendered %>
                            <small class="text-muted fst-italic">Ver acima</small>
                          <% elsif is_sem_tabela %>
                            <span class="badge bg-warning text-dark"><i class="bi bi-slash-circle"></i> Sem ref. tabela</span>
                          <% elsif ref.present? %>
                            <strong><%= CustomHelper.to_currency(ref.reference_price) %></strong>
                            <% if exceeded %>
                              <br><small class="text-warning"><i class="bi bi-info-circle"></i> +<%= diff_percent %>% vs tabela</small>
                            <% end %>
                          <% else %>
                            <span class="text-muted">-</span>
                          <% end %>
                        </td>
                        <td>
                          <% if service_id.present? && @vehicle_model.present? && can_edit && !already_rendered %>
                            <%= text_field_tag "reference_prices[#{service_id}][reference_code]",
                              ref&.reference_code,
                              class: 'form-control form-control-sm',
                              placeholder: 'Código' %>
                          <% elsif ref.present? %>
                            <small><%= ref.reference_code.presence || '-' %></small>
                          <% else %>-<% end %>
                        </td>
                        <td class="text-center">
                          <% if service_id.present? && @vehicle_model.present? && can_edit && !already_rendered %>
                            <div id="pct-input-<%= service_id %>" class="<%= is_sem_tabela ? 'd-none' : '' %>">
                              <%= number_field_tag "reference_prices[#{service_id}][max_percentage]",
                                (!is_sem_tabela && ref.present?) ? ref.max_percentage : 110,
                                class: 'form-control form-control-sm text-center',
                                min: 100, step: 0.1, style: 'width: 65px' %>
                            </div>
                            <% if is_sem_tabela %>—<% end %>
                          <% elsif ref.present? && !is_sem_tabela %>
                            <%= ref.max_percentage %>%
                          <% else %>-<% end %>
                        </td>
                        <td>
                          <% if service_id.present? && @vehicle_model.present? && can_edit && !already_rendered %>
                            <%= text_field_tag "reference_prices[#{service_id}][source]",
                              ref.present? ? ref.source : (is_sem_tabela ? "Sem ref. tabela #{Date.current.strftime('%m/%Y')}" : "Cilia #{Date.current.strftime('%m/%Y')}"),
                              class: 'form-control form-control-sm',
                              id: "source_#{service_id}",
                              placeholder: 'Fonte' %>
                          <% elsif ref.present? %>
                            <small><%= ref.source || '-' %></small>
                          <% else %>-<% end %>
                        </td>
                        <td class="text-center">
                          <% if is_sem_tabela %>
                            <span class="badge bg-warning text-dark" data-bs-toggle="tooltip" title="Sem referência de tabela. Pesquisa de mercado registrada com <%= hist_count %> cotação(ões).">
                              <i class="bi bi-search"></i> Pesq. Mercado
                            </span>
                          <% elsif ref.present? %>
                            <% if exceeded %>
                              <span class="badge bg-warning text-dark" data-bs-toggle="tooltip"
                                title="Cobrado: <%= CustomHelper.to_currency(provider_price) %> | Máx. tabela: <%= CustomHelper.to_currency(ref.max_allowed_price) %>">
                                <i class="bi bi-info-circle"></i> +<%= diff_percent %>% vs tabela
                              </span>
                            <% else %>
                              <span class="badge bg-success"><i class="bi bi-check-circle"></i> OK</span>
                            <% end %>
                          <% elsif service_id.blank? %>
                            <span class="badge bg-secondary" data-bs-toggle="tooltip" title="Item sem serviço vinculado">
                              <i class="bi bi-dash-circle"></i> N/A
                            </span>
                          <% elsif @vehicle_model.blank? %>
                            <span class="badge bg-secondary" data-bs-toggle="tooltip" title="Veículo sem modelo vinculado">
                              <i class="bi bi-link"></i> Sem modelo
                            </span>
                          <% else %>
                            <span class="badge bg-warning text-dark"><i class="bi bi-clock"></i> Pendente</span>
                          <% end %>
                        </td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            <% end %>

            <% if pd[:services].any? %>
              <!-- Tabela de Serviços (somente visualização) -->
              <div class="px-3 pt-3">
                <h6 class="text-muted mb-0">
                  <i class="bi bi-wrench"></i> Serviços (<%= pd[:services].size %>) 
                  <small class="text-muted">(somente visualização)</small>
                </h6>
              </div>
              <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                  <thead class="table-light">
                    <tr>
                      <th>Serviço</th>
                      <th class="text-end">Valor Unitário (R$)</th>
                      <th class="text-center">Qtd</th>
                      <th class="text-end">Total (R$)</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% pd[:services].each do |svc| %>
                      <tr class="table-secondary">
                        <td><%= svc.service_name.presence || svc.service&.name || '-' %></td>
                        <td class="text-end"><%= CustomHelper.to_currency(svc.unity_value) %></td>
                        <td class="text-center"><%= svc.quantity %></td>
                        <td class="text-end"><%= CustomHelper.to_currency(svc.total_value) %></td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Botões de ação -->
      <div class="row mb-4">
        <div class="col-12 d-flex gap-2">
          <% if can_edit && @vehicle_model.present? %>
            <%= submit_tag 'Salvar Preços de Referência', class: 'btn btn-primary' %>
          <% end %>
          <% if can_complete && @order_service.cilia_priced_at.blank? %>
            <%= link_to mark_complete_cilia_pricing_path(@order_service),
              method: :patch,
              class: 'btn btn-success',
              data: { confirm: 'Marcar esta OS como precificada pelo Cilia?' } do %>
              <i class="bi bi-check-circle"></i> Salvar e Marcar como Precificada
            <% end %>
          <% end %>
          <%= link_to cilia_pricing_index_path, class: 'btn btn-outline-secondary' do %>
            <i class="bi bi-arrow-left"></i> Voltar à Lista
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="card">
      <div class="card-body text-center py-5">
        <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
        <p class="text-muted mt-2">Esta OS não possui propostas com itens.</p>
        <%= link_to 'Voltar à Lista', cilia_pricing_index_path, class: 'btn btn-outline-secondary' %>
      </div>
    </div>
  <% end %>
</div>

<style>
.cilia-price-input:focus { border-color: #0d6efd; box-shadow: 0 0 0 0.15rem rgba(13, 110, 253, 0.25); }
.table td { vertical-align: middle; }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
  tooltipTriggerList.forEach(function(el) { new bootstrap.Tooltip(el); });

  // Toggle sem_tabela: oculta/exibe campos de preço e % ao marcar
  document.querySelectorAll('.sem-tabela-check').forEach(function(chk) {
    chk.addEventListener('change', function() {
      var sid = this.dataset.serviceId;
      var priceDiv = document.getElementById('price-input-' + sid);
      var pctDiv   = document.getElementById('pct-input-' + sid);
      var sourceEl = document.getElementById('source_' + sid);
      var lbl = document.querySelector('label[for="sem_tabela_' + sid + '"]');

      if (this.checked) {
        if (priceDiv) priceDiv.classList.add('d-none');
        if (pctDiv)   pctDiv.classList.add('d-none');
        if (sourceEl) sourceEl.value = 'Sem ref. tabela <%= Date.current.strftime("%m/%Y") %>';
        if (lbl) { lbl.classList.remove('btn-outline-secondary'); lbl.classList.add('btn-warning'); }
      } else {
        if (priceDiv) priceDiv.classList.remove('d-none');
        if (pctDiv)   pctDiv.classList.remove('d-none');
        if (sourceEl && sourceEl.value.startsWith('Sem ref.')) {
          sourceEl.value = 'Cilia <%= Date.current.strftime("%m/%Y") %>';
        }
        if (lbl) { lbl.classList.remove('btn-warning'); lbl.classList.add('btn-outline-secondary'); }
      }
    });
  });
});
</script>
