<!-- Info Banner -->
<div class="alert alert-info border-0 shadow-sm d-flex align-items-start" role="alert">
  <i class="bi bi-info-circle fs-5 me-3 mt-1"></i>
  <div>
    <strong>Gerar Faturas:</strong> Selecione ordens de serviço autorizadas (com proposta aprovada) que ainda
    não foram faturadas para gerar uma nova fatura ao cliente.
  </div>
</div>

<div class="alert alert-warning border-0 shadow-sm d-flex align-items-start" role="alert">
  <i class="bi bi-file-earmark-text fs-5 me-3 mt-1"></i>
  <div>
    <strong>Nota Fiscal:</strong> A NF precisa conter em sua descrição: <strong>período apurado</strong>,
    <strong>nome do centro de custo</strong> e <strong>unidade</strong>.
  </div>
</div>

<!-- Filters -->
<div class="row mb-3 g-2">
  <div class="col-md-4">
    <label class="form-label small text-muted">Selecionar Cliente</label>
    <select class="form-select" id="fAbertoCliente" onchange="Faturamento.carregarOSAbertos()">
      <option value="">Selecione o cliente...</option>
      <% clients.each do |c| %>
        <option value="<%= c.id %>"><%= c.fantasy_name.presence || c.social_name.presence || c.name %></option>
      <% end %>
    </select>
  </div>
  <div class="col-md-3">
    <label class="form-label small text-muted">Centro de Custo</label>
    <select class="form-select" id="fAbertoCentroCusto" onchange="Faturamento.filtrarOSAbertos()" disabled>
      <option value="">Todos</option>
    </select>
  </div>
  <div class="col-md-3">
    <label class="form-label small text-muted">Subunidade</label>
    <select class="form-select" id="fAbertoSubUnidade" onchange="Faturamento.filtrarOSAbertos()" disabled>
      <option value="">Todas</option>
    </select>
  </div>
  <div class="col-md-2 d-flex align-items-end">
    <button class="btn btn-outline-secondary w-100" onclick="Faturamento.limparFiltrosAbertos()" disabled id="btnLimparAbertos">
      <i class="bi bi-x-circle"></i> Limpar
    </button>
  </div>
</div>

<!-- OS em Aberto Content -->
<div id="abertosContent">
  <p class="text-center text-muted py-5">
    Selecione um cliente para listar as OS em aberto para faturamento.
  </p>
</div>

<!-- Preview Section (hidden) -->
<div id="previewSection" style="display:none">
  <button class="btn btn-outline-secondary btn-sm mb-3" onclick="Faturamento.voltarSelecao()">
    <i class="bi bi-arrow-left"></i> Voltar à seleção
  </button>
  <div id="previewAvisos"></div>
  <div id="previewContent"></div>
</div>

<!-- Success Section (hidden) -->
<div id="successSection" style="display:none">
  <div class="card border-0 shadow-sm text-center py-5">
    <i class="bi bi-check-circle text-success" style="font-size:3rem"></i>
    <div id="successMsg" class="mt-3 fs-5"></div>
    <div id="successActions" class="mt-4"></div>
  </div>
</div>
