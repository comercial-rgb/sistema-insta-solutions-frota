<!-- Filters Bar -->
<div class="card border-0 shadow-sm mb-3">
  <div class="card-body py-3">
    <div class="row g-2 align-items-end">
      <div class="col-md-3">
        <label class="form-label small text-muted mb-1">Buscar nº fatura</label>
        <input type="text" class="form-control form-control-sm" id="fSearch"
               placeholder="Buscar nº fatura..." data-action="input" onkeyup="Faturamento.debouncedLoadFaturas()">
      </div>
      <div class="col-md-2">
        <label class="form-label small text-muted mb-1">Status</label>
        <select class="form-select form-select-sm" id="fStatus" onchange="Faturamento.loadFaturas()">
          <option value="">Todos os status</option>
          <option value="aberta">Aberta</option>
          <option value="enviada">Enviada</option>
          <option value="paga">Paga</option>
          <option value="cancelada">Cancelada</option>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label small text-muted mb-1">Fornecedor</label>
        <select class="form-select form-select-sm" id="fProvider" onchange="Faturamento.loadFaturas()">
          <option value="">Todos os fornecedores</option>
          <% providers.each do |p| %>
            <option value="<%= p.id %>"><%= p.name %></option>
          <% end %>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label small text-muted mb-1">Centro de Custo</label>
        <select class="form-select form-select-sm" id="fCostCenter" onchange="Faturamento.loadFaturas()">
          <option value="">Todos os C.C.</option>
          <% cost_centers.each do |cc| %>
            <option value="<%= cc.id %>"><%= cc.name %></option>
          <% end %>
        </select>
      </div>
      <div class="col-md-1">
        <label class="form-label small text-muted mb-1">Data início</label>
        <input type="date" class="form-control form-control-sm" id="fDtIni" onchange="Faturamento.loadFaturas()">
      </div>
      <div class="col-md-1">
        <label class="form-label small text-muted mb-1">Data fim</label>
        <input type="date" class="form-control form-control-sm" id="fDtFim" onchange="Faturamento.loadFaturas()">
      </div>
      <div class="col-auto">
        <button class="btn btn-outline-secondary btn-sm" onclick="Faturamento.limparFiltros()" title="Limpar filtros">
          <i class="bi bi-x-circle"></i>
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Faturas Table -->
<div class="card border-0 shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr>
          <th class="text-uppercase small text-muted">Nº</th>
          <th class="text-uppercase small text-muted">Fornecedor</th>
          <th class="text-uppercase small text-muted">C.Custo</th>
          <th class="text-uppercase small text-muted">Emissão</th>
          <th class="text-uppercase small text-muted">Vencimento</th>
          <th class="text-uppercase small text-muted">Envio</th>
          <th class="text-uppercase small text-muted">V.Bruto</th>
          <th class="text-uppercase small text-muted">V.Líquido</th>
          <th class="text-uppercase small text-muted">Status</th>
          <th class="text-uppercase small text-muted" style="min-width:120px">Ações</th>
        </tr>
      </thead>
      <tbody id="faturasBody">
        <% if faturas.any? %>
          <% faturas.each do |f| %>
            <tr>
              <td>
                <strong class="text-primary" style="cursor:pointer" onclick="Faturamento.verDetalhe(<%= f.id %>)">
                  <%= f.numero %>
                </strong>
              </td>
              <td><%= f.provider&.name || '-' %></td>
              <td><%= f.cost_center&.name || '-' %></td>
              <td><%= f.data_emissao&.strftime('%d/%m/%Y') %></td>
              <td>
                <% if f.vencida? %>
                  <span class="text-danger fw-bold" title="Vencida!">
                    <i class="bi bi-exclamation-triangle-fill"></i> <%= f.data_vencimento&.strftime('%d/%m/%Y') %>
                  </span>
                <% else %>
                  <%= f.data_vencimento&.strftime('%d/%m/%Y') || '-' %>
                <% end %>
              </td>
              <td><%= f.data_envio_empresa&.strftime('%d/%m/%Y') || '-' %></td>
              <td><%= number_to_currency(f.valor_bruto, unit: 'R$ ') %></td>
              <td><%= number_to_currency(f.valor_liquido, unit: 'R$ ') %></td>
              <td><%= render 'faturamento/shared/status_badge', status: f.status %></td>
              <td>
                <div class="dropdown">
                  <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                          data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-three-dots-vertical"></i>
                  </button>
                  <ul class="dropdown-menu dropdown-menu-end">
                    <li>
                      <a class="dropdown-item" href="#" onclick="Faturamento.verDetalhe(<%= f.id %>); return false;">
                        <i class="bi bi-eye-fill me-2"></i> Ver Detalhes
                      </a>
                    </li>
                    <% if policy(:faturamento).update? %>
                      <li>
                        <a class="dropdown-item" href="#" onclick="Faturamento.editarFatura(<%= f.id %>); return false;">
                          <i class="bi bi-pencil-fill me-2"></i> Editar
                        </a>
                      </li>
                      <% if f.status == 'aberta' %>
                        <li>
                          <a class="dropdown-item" href="#" onclick="Faturamento.enviarCobranca(<%= f.id %>); return false;">
                            <i class="bi bi-send-fill me-2"></i> Enviar Cobrança
                          </a>
                        </li>
                      <% end %>
                    <% end %>
                  </ul>
                </div>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="10" class="text-center text-muted py-4">Nenhuma fatura encontrada</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <div class="card-footer bg-white d-flex justify-content-between align-items-center">
    <span class="small text-muted">
      <%= "Página #{faturas.current_page} de #{faturas.total_pages} (#{faturas.total_count} faturas)" if faturas.respond_to?(:current_page) %>
    </span>
    <div>
      <%= paginate faturas, theme: 'bootstrap-5' if faturas.respond_to?(:current_page) %>
    </div>
  </div>
</div>
