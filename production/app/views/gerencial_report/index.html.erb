<%
breadcrumbs = [
  {active: false, href: root_path, text: t('menu.initial_page')},
  {active: true, href: '#', text: 'Relatório Gerencial'},
]
%>

<div class="container-fluid">
  <%= render 'common_pages/breadcrumb', links: breadcrumbs %>

  <div class="row mb-4">
    <div class="col-12">
      <h4 class="mb-0">
        <i class="bi bi-graph-up-arrow text-primary"></i>
        Relatório Gerencial
      </h4>
      <p class="text-muted">Visão consolidada dos indicadores operacionais e financeiros</p>
    </div>
  </div>

  <!-- Filtros de Período -->
  <div class="card shadow-sm mb-4">
    <div class="card-header bg-primary text-white">
      <i class="bi bi-funnel me-2"></i>Período de Análise
    </div>
    <div class="card-body">
      <%= form_with url: gerencial_report_path, method: :get, local: true, class: 'row g-3 align-items-end' do %>
        <div class="col-md-3">
          <%= label_tag :start_date, 'Data Início', class: 'form-label' %>
          <%= date_field_tag :start_date, @start_date, class: 'form-control' %>
        </div>
        <div class="col-md-3">
          <%= label_tag :end_date, 'Data Fim', class: 'form-label' %>
          <%= date_field_tag :end_date, @end_date, class: 'form-control' %>
        </div>
        <div class="col-md-2">
          <button type="submit" class="btn btn-primary w-100">
            <i class="bi bi-search me-1"></i>Gerar Relatório
          </button>
        </div>
        <% if @metrics.present? %>
          <div class="col-md-4 text-end">
            <%= link_to gerencial_report_export_path(start_date: @start_date, end_date: @end_date, format: :xlsx), id: 'btn-export-xlsx', class: 'btn btn-success me-2' do %>
              <i class="bi bi-file-earmark-excel me-1"></i>Exportar Excel
            <% end %>
            <%= link_to gerencial_report_export_path(start_date: @start_date, end_date: @end_date, format: :pdf), id: 'btn-export-pdf', class: 'btn btn-danger' do %>
              <i class="bi bi-file-earmark-pdf me-1"></i>Exportar PDF
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

  <% if @metrics.present? %>
    <!-- Cards de Resumo -->
    <div class="row g-3 mb-4">
      <!-- OS -->
      <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body text-center">
            <div class="text-primary mb-2"><i class="bi bi-clipboard2-data" style="font-size: 2rem;"></i></div>
            <h3 class="fw-bold mb-0"><%= @metrics[:os_abertas] %></h3>
            <small class="text-muted">OS Abertas no Período</small>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body text-center">
            <div class="text-success mb-2"><i class="bi bi-clipboard2-check" style="font-size: 2rem;"></i></div>
            <h3 class="fw-bold mb-0"><%= @metrics[:os_respondidas] %></h3>
            <small class="text-muted">OS Respondidas</small>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body text-center">
            <div class="text-info mb-2"><i class="bi bi-currency-dollar" style="font-size: 2rem;"></i></div>
            <h3 class="fw-bold mb-0">R$ <%= number_with_delimiter(@metrics[:valor_aprovado_os], delimiter: '.', separator: ',') %></h3>
            <small class="text-muted">Valor Aprovado de OS</small>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body text-center">
            <div class="text-warning mb-2"><i class="bi bi-exclamation-triangle" style="font-size: 2rem;"></i></div>
            <h3 class="fw-bold mb-0"><%= @metrics[:faturas_vencidas] %></h3>
            <small class="text-muted">Faturas Vencidas</small>
            <div class="text-danger small fw-bold">R$ <%= number_with_delimiter(@metrics[:valor_faturas_vencidas], delimiter: '.', separator: ',') %></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Detalhes em Duas Colunas -->
    <div class="row g-3 mb-4">
      <!-- Coluna Esquerda -->
      <div class="col-md-6">
        <!-- Clientes e Fornecedores -->
        <div class="card shadow-sm mb-3">
          <div class="card-header"><i class="bi bi-people me-2"></i>Clientes & Fornecedores</div>
          <div class="card-body p-0">
            <table class="table table-sm mb-0">
              <tbody>
                <tr><td class="ps-3">Clientes Ativos</td><td class="text-end pe-3 fw-bold"><%= @metrics[:clientes_ativos] %></td></tr>
                <tr><td class="ps-3">Clientes Novos no Período</td><td class="text-end pe-3 fw-bold text-success"><%= @metrics[:clientes_novos] %></td></tr>
                <tr><td class="ps-3">Fornecedores Ativos</td><td class="text-end pe-3 fw-bold"><%= @metrics[:fornecedores_ativos] %></td></tr>
                <tr><td class="ps-3">Fornecedores Novos no Período</td><td class="text-end pe-3 fw-bold text-success"><%= @metrics[:fornecedores_novos] %></td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Contratos -->
        <div class="card shadow-sm mb-3">
          <div class="card-header"><i class="bi bi-file-earmark-text me-2"></i>Contratos</div>
          <div class="card-body p-0">
            <table class="table table-sm mb-0">
              <tbody>
                <tr><td class="ps-3">Contratos Ativos</td><td class="text-end pe-3 fw-bold"><%= @metrics[:contratos_ativos] %></td></tr>
                <tr><td class="ps-3">Contratos Novos no Período</td><td class="text-end pe-3 fw-bold text-success"><%= @metrics[:contratos_novos] %></td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Chamados -->
        <div class="card shadow-sm mb-3">
          <div class="card-header"><i class="bi bi-headset me-2"></i>Chamados</div>
          <div class="card-body p-0">
            <table class="table table-sm mb-0">
              <tbody>
                <tr><td class="ps-3">Chamados Abertos no Período</td><td class="text-end pe-3 fw-bold"><%= @metrics[:chamados_abertos] %></td></tr>
                <tr><td class="ps-3">Chamados Resolvidos no Período</td><td class="text-end pe-3 fw-bold text-success"><%= @metrics[:chamados_resolvidos] %></td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Coluna Direita -->
      <div class="col-md-6">
        <!-- Faturas -->
        <div class="card shadow-sm mb-3">
          <div class="card-header"><i class="bi bi-receipt me-2"></i>Faturas</div>
          <div class="card-body p-0">
            <table class="table table-sm mb-0">
              <tbody>
                <tr><td class="ps-3">Faturas Geradas</td><td class="text-end pe-3 fw-bold"><%= @metrics[:faturas_geradas] %></td></tr>
                <tr><td class="ps-3">Valor Faturas Geradas</td><td class="text-end pe-3 fw-bold">R$ <%= number_with_delimiter(@metrics[:valor_faturas_geradas], delimiter: '.', separator: ',') %></td></tr>
                <tr><td class="ps-3">Faturas Pagas</td><td class="text-end pe-3 fw-bold text-success"><%= @metrics[:faturas_pagas] %></td></tr>
                <tr><td class="ps-3">Valor Faturas Pagas</td><td class="text-end pe-3 fw-bold text-success">R$ <%= number_with_delimiter(@metrics[:valor_faturas_pagas], delimiter: '.', separator: ',') %></td></tr>
                <tr class="table-danger"><td class="ps-3">Faturas Vencidas</td><td class="text-end pe-3 fw-bold"><%= @metrics[:faturas_vencidas] %></td></tr>
                <tr class="table-danger"><td class="ps-3">Valor Faturas Vencidas</td><td class="text-end pe-3 fw-bold">R$ <%= number_with_delimiter(@metrics[:valor_faturas_vencidas], delimiter: '.', separator: ',') %></td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- OS por Status -->
        <div class="card shadow-sm mb-3">
          <div class="card-header"><i class="bi bi-bar-chart me-2"></i>OS por Status</div>
          <div class="card-body p-0">
            <table class="table table-sm mb-0">
              <thead class="table-light">
                <tr><th class="ps-3">Status</th><th class="text-end pe-3">Quantidade</th></tr>
              </thead>
              <tbody>
                <% @metrics[:os_por_status].each do |status, count| %>
                  <tr><td class="ps-3"><%= status %></td><td class="text-end pe-3 fw-bold"><%= count %></td></tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- Contratos com Vencimento Próximo -->
    <% if @metrics[:contratos_vencendo].present? && @metrics[:contratos_vencendo].any? %>
      <div class="card shadow-sm mb-4">
        <div class="card-header bg-danger text-white">
          <i class="bi bi-calendar-x me-2"></i>Contratos com Vencimento em até 60 dias
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th class="ps-3">Cliente</th>
                  <th>Contrato</th>
                  <th>Nº</th>
                  <th>Vencimento</th>
                  <th class="text-end pe-3">Dias Restantes</th>
                </tr>
              </thead>
              <tbody>
                <% @metrics[:contratos_vencendo].each do |item| %>
                  <tr>
                    <td class="ps-3"><%= item[:client] %></td>
                    <td><%= item[:contract] %></td>
                    <td><%= item[:number] %></td>
                    <td><%= item[:final_date]&.strftime('%d/%m/%Y') %></td>
                    <td class="text-end pe-3">
                      <span class="badge bg-<%= item[:urgency] %>">
                        <%= item[:days_left] %> dias
                      </span>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Clientes com Saldo Baixo -->
    <% if @metrics[:clientes_saldo_baixo].any? %>
      <div class="card shadow-sm mb-4">
        <div class="card-header bg-warning text-dark">
          <i class="bi bi-exclamation-triangle me-2"></i>Clientes com Saldo Baixo (< 20% disponível)
          <small class="d-block">Considera valor efetivamente consumido por OS (não apenas empenhado)</small>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th class="ps-3">Cliente</th>
                  <th>Contrato</th>
                  <th class="text-end">Valor Total</th>
                  <th class="text-end">Empenhado</th>
                  <th class="text-end">Consumido (OS)</th>
                  <th class="text-end">Saldo Real</th>
                  <th class="text-end pe-3">% Disponível</th>
                </tr>
              </thead>
              <tbody>
                <% @metrics[:clientes_saldo_baixo].each do |item| %>
                  <tr>
                    <td class="ps-3"><%= item[:client] %></td>
                    <td><%= item[:contract] %> <small class="text-muted">(<%= item[:number] %>)</small></td>
                    <td class="text-end">R$ <%= number_with_delimiter(item[:total], delimiter: '.', separator: ',') %></td>
                    <td class="text-end">R$ <%= number_with_delimiter(item[:empenhado], delimiter: '.', separator: ',') %></td>
                    <td class="text-end">R$ <%= number_with_delimiter(item[:consumed], delimiter: '.', separator: ',') %></td>
                    <td class="text-end fw-bold">R$ <%= number_with_delimiter(item[:available], delimiter: '.', separator: ',') %></td>
                    <td class="text-end pe-3">
                      <span class="badge <%= item[:pct] < 10 ? 'bg-danger' : 'bg-warning text-dark' %>">
                        <%= item[:pct] %>%
                      </span>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Observações -->
    <div class="card shadow-sm mb-4">
      <div class="card-header">
        <i class="bi bi-pencil-square me-2"></i>Observações
      </div>
      <div class="card-body">
        <textarea id="gerencial-observacoes" class="form-control" rows="4"
          placeholder="Adicione observações livres que serão incluídas no relatório exportado..."><%= params[:observacoes] %></textarea>
        <small class="text-muted mt-1 d-block">O conteúdo será incluído nos arquivos PDF e Excel ao exportar.</small>
      </div>
    </div>

  <% else %>
    <div class="card shadow-sm">
      <div class="card-body text-center py-5">
        <i class="bi bi-graph-up-arrow text-muted" style="font-size: 4rem;"></i>
        <h5 class="mt-3 text-muted">Selecione um período e clique em "Gerar Relatório"</h5>
        <p class="text-muted">Os indicadores serão exibidos aqui</p>
      </div>
    </div>
  <% end %>

<script>
  (function () {
    var obs     = document.getElementById('gerencial-observacoes');
    var xlsxBtn = document.getElementById('btn-export-xlsx');
    var pdfBtn  = document.getElementById('btn-export-pdf');
    if (!obs || !xlsxBtn || !pdfBtn) return;

    function updateLinks() {
      var val = obs.value.trim();
      [xlsxBtn, pdfBtn].forEach(function (btn) {
        var url = new URL(btn.href, window.location.origin);
        if (val) {
          url.searchParams.set('observacoes', val);
        } else {
          url.searchParams.delete('observacoes');
        }
        btn.href = url.toString();
      });
    }

    obs.addEventListener('input', updateLinks);
    updateLinks();
  })();
</script>
</div>
