<%
breadcrumbs = [
  {active: false, href: root_path, text: t('menu.initial_page')},
  {active: true,  href: '#', text: 'Benchmark de Desempenho'},
]
%>

<div class="container-fluid">
  <%= render 'common_pages/breadcrumb', links: breadcrumbs %>

  <div class="row mb-4 align-items-center">
    <div class="col">
      <h4 class="mb-0">
        <i class="bi bi-speedometer2 text-primary me-2"></i>Benchmark de Desempenho — TR 5.51
      </h4>
      <p class="text-muted mb-0">
        Tempo de resposta das operações críticas do sistema medido ao vivo com dados reais.
        SLA exigido: <strong>&lt; 2.000 ms</strong> por operação.
      </p>
    </div>
    <div class="col-auto">
      <%= link_to performance_benchmark_path, class: 'btn btn-outline-primary' do %>
        <i class="bi bi-arrow-clockwise me-1"></i> Executar novamente
      <% end %>
    </div>
  </div>

  <%# Resultado geral %>
  <div class="alert <%= @overall_pass ? 'alert-success' : 'alert-danger' %> d-flex align-items-center mb-4 shadow-sm">
    <i class="bi <%= @overall_pass ? 'bi-check-circle-fill' : 'bi-x-circle-fill' %> fs-3 me-3"></i>
    <div>
      <strong class="fs-5">
        <%= @overall_pass ? 'Sistema dentro do SLA — todas as operações abaixo de 2 segundos' : "#{@fail_count} operação(ões) acima do SLA de 2 segundos" %>
      </strong>
      <div class="small mt-1">
        Executado em: <strong><%= @started_at.strftime('%d/%m/%Y às %H:%M:%S') %></strong> &nbsp;|&nbsp;
        Tempo total da página: <strong><%= @total_ms %> ms</strong> &nbsp;|&nbsp;
        Aprovadas: <strong class="text-success"><%= @pass_count %></strong> &nbsp;|&nbsp;
        Reprovadas: <strong class="text-danger"><%= @fail_count %></strong>
      </div>
    </div>
  </div>

  <%# Tabela de resultados %>
  <div class="card shadow-sm mb-4">
    <div class="card-header bg-light fw-bold">
      <i class="bi bi-table me-2"></i>Resultados por Operação
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Operação</th>
              <th class="text-center">Registros</th>
              <th class="text-end">Tempo (ms)</th>
              <th class="text-center" style="width: 140px;">Status SLA</th>
            </tr>
          </thead>
          <tbody>
            <% @results.each do |r| %>
              <tr class="<%= r[:pass] ? '' : 'table-danger' %>">
                <td>
                  <i class="bi <%= r[:pass] ? 'bi-check-circle text-success' : 'bi-exclamation-triangle text-danger' %> me-2"></i>
                  <%= r[:label] %>
                  <% if r[:error] %>
                    <br><small class="text-danger"><i class="bi bi-bug me-1"></i><%= r[:error] %></small>
                  <% end %>
                </td>
                <td class="text-center">
                  <span class="badge bg-secondary"><%= r[:count] %></span>
                </td>
                <td class="text-end">
                  <% if r[:ms] %>
                    <%
                      bar_pct  = [r[:ms] / 2000.0 * 100, 100].min
                      bar_class = r[:ms] < 500  ? 'bg-success' :
                                  r[:ms] < 1000 ? 'bg-info'    :
                                  r[:ms] < 1500 ? 'bg-warning' :
                                  r[:ms] < 2000 ? 'bg-orange'  : 'bg-danger'
                    %>
                    <div class="d-flex align-items-center justify-content-end gap-2">
                      <div class="progress flex-grow-1" style="height: 6px; max-width: 120px;">
                        <div class="progress-bar <%= bar_class %>" style="width: <%= bar_pct %>%"></div>
                      </div>
                      <strong style="min-width: 70px; text-align: right;">
                        <%= number_with_delimiter(r[:ms], delimiter: '.') %> ms
                      </strong>
                    </div>
                  <% else %>
                    <span class="text-muted">—</span>
                  <% end %>
                </td>
                <td class="text-center">
                  <% if r[:ms] %>
                    <span class="badge fs-6 <%= r[:pass] ? 'bg-success' : 'bg-danger' %>">
                      <%= r[:pass] ? '✓ OK' : '✗ LENTO' %>
                    </span>
                  <% else %>
                    <span class="badge bg-secondary">ERRO</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
          <tfoot class="table-light fw-bold">
            <tr>
              <td>TEMPO TOTAL DA PÁGINA (servidor + todas as operações)</td>
              <td></td>
              <td class="text-end">
                <strong class="<%= @total_ms < 2000 ? 'text-success' : 'text-danger' %>">
                  <%= number_with_delimiter(@total_ms, delimiter: '.') %> ms
                </strong>
              </td>
              <td class="text-center">
                <span class="badge fs-6 <%= @total_ms < 2000 ? 'bg-success' : 'bg-danger' %>">
                  <%= @total_ms < 2000 ? '✓ OK' : '✗ LENTO' %>
                </span>
              </td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>
  </div>

  <%# Legenda de cores %>
  <div class="card shadow-sm mb-4">
    <div class="card-header bg-light fw-bold"><i class="bi bi-info-circle me-2"></i>Legenda</div>
    <div class="card-body">
      <div class="d-flex flex-wrap gap-3">
        <span><span class="badge bg-success">0 – 499 ms</span> Excelente</span>
        <span><span class="badge bg-info text-dark">500 – 999 ms</span> Bom</span>
        <span><span class="badge bg-warning text-dark">1.000 – 1.499 ms</span> Aceitável</span>
        <span><span class="badge bg-danger">≥ 2.000 ms</span> Acima do SLA</span>
      </div>
    </div>
  </div>

  <%# Nota sobre Server-Timing %>
  <div class="card shadow-sm border-0 bg-light">
    <div class="card-body">
      <h6 class="fw-bold mb-2"><i class="bi bi-tools me-2"></i>Server-Timing — verificação via DevTools</h6>
      <p class="mb-2 small">
        Todas as páginas do sistema retornam o header <code>Server-Timing: app;desc="Rails";dur=XX.X</code>
        e <code>X-Response-Time: XXms</code>. Para verificar qualquer página:
      </p>
      <ol class="small mb-0">
        <li>Abra o navegador → <kbd>F12</kbd> → aba <strong>Network</strong></li>
        <li>Navegue para qualquer página do sistema</li>
        <li>Clique na requisição → <strong>Headers</strong> → procure <code>Server-Timing</code> e <code>X-Response-Time</code></li>
        <li>O valor <code>dur=XX.X</code> é o tempo de processamento no servidor em milissegundos</li>
      </ol>
    </div>
  </div>
</div>
