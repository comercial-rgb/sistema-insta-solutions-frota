<%
breadcrumbs = [
  {active: false, href: root_path, text: t('menu.initial_page')},
  {active: false, href: custom_reports_path, text: 'Relatórios Personalizados'},
  {active: true,  href: '#', text: 'Por Estabelecimento Credenciado'},
]
%>

<div class="container-fluid">
  <%= render 'common_pages/breadcrumb', links: breadcrumbs %>

  <div class="row mb-4">
    <div class="col-12">
      <h4 class="mb-0">
        <i class="bi bi-shop text-primary"></i>
        Relatório por Estabelecimento Credenciado
      </h4>
      <p class="text-muted mb-0">Valores transacionados, quantidade de transações e representatividade percentual de cada fornecedor no contrato.</p>
      <p class="text-muted small"><i class="bi bi-info-circle me-1"></i>Taxa secundária disponível no <a href="<%= financial_portal_path %>">Portal Financeiro</a>.</p>
    </div>
  </div>

  <!-- Filtros -->
  <div class="card shadow-sm mb-4">
    <div class="card-header bg-primary text-white">
      <i class="bi bi-funnel me-2"></i>Filtros
    </div>
    <div class="card-body">
      <%= form_with url: provider_report_path, method: :get, local: true, class: 'row g-3' do |f| %>

        <% if @current_user.admin? %>
          <div class="col-md-4">
            <%= label_tag :client_id, 'Cliente', class: 'form-label' %>
            <%= select_tag :client_id,
                options_for_select(@clients_options, params[:client_id]),
                { include_blank: 'Selecione o cliente', class: 'form-select' } %>
          </div>
        <% end %>

        <div class="col-md-3">
          <%= label_tag :start_date, 'Data Inicial', class: 'form-label' %>
          <%= date_field_tag :start_date, params[:start_date], class: 'form-control' %>
        </div>

        <div class="col-md-3">
          <%= label_tag :end_date, 'Data Final', class: 'form-label' %>
          <%= date_field_tag :end_date, params[:end_date], class: 'form-control' %>
        </div>

        <div class="col-12">
          <div class="d-flex gap-2 flex-wrap">
            <%= submit_tag 'Filtrar', class: 'btn btn-primary' %>
            <%= link_to 'Limpar', provider_report_path, class: 'btn btn-secondary' %>

            <div class="ms-auto d-flex gap-2">
              <% if @provider_rows.any? %>
                <%= button_tag type: :submit, name: :format, value: 'pdf', class: 'btn btn-danger', formtarget: '_blank' do %>
                  <i class="bi bi-file-pdf me-1"></i> Exportar PDF
                <% end %>
                <%= button_tag type: :submit, name: :format, value: 'csv', class: 'btn btn-success' do %>
                  <i class="bi bi-file-earmark-spreadsheet me-1"></i> Exportar CSV
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Resultado -->
  <div class="card shadow-sm">
    <div class="card-header bg-light d-flex justify-content-between align-items-center">
      <span><i class="bi bi-table me-2"></i>Estabelecimentos encontrados: <strong><%= @provider_rows.size %></strong></span>
      <% if @provider_rows.any? %>
        <span class="badge bg-primary fs-6">
          Total Líquido: <%= number_to_currency(@grand_total_net, unit: 'R$ ', separator: ',', delimiter: '.', precision: 2) %>
        </span>
      <% end %>
    </div>
    <div class="card-body p-0">
      <% if @provider_rows.any? %>
        <div class="table-responsive">
          <table class="table table-hover table-striped align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Estabelecimento</th>
                <th class="text-center">Nº Transações</th>
                <th class="text-end">Valor Bruto</th>
                <th class="text-end">Valor Líquido</th>
                <th class="text-center">% do Contrato</th>
              </tr>
            </thead>
            <tbody>
              <% @provider_rows.each do |row| %>
                <tr>
                  <td><strong><%= row[:name] %></strong></td>
                  <td class="text-center">
                    <span class="badge bg-secondary"><%= row[:transactions] %></span>
                  </td>
                  <td class="text-end text-muted">
                    <%= number_to_currency(row[:gross_value], unit: 'R$ ', separator: ',', delimiter: '.', precision: 2) %>
                  </td>
                  <td class="text-end">
                    <strong><%= number_to_currency(row[:net_value], unit: 'R$ ', separator: ',', delimiter: '.', precision: 2) %></strong>
                  </td>
                  <td class="text-center">
                    <div class="d-flex align-items-center justify-content-center gap-2">
                      <div class="progress flex-grow-1" style="height: 8px; max-width: 80px;">
                        <div class="progress-bar bg-primary" role="progressbar"
                          style="width: <%= row[:pct] %>%"
                          aria-valuenow="<%= row[:pct] %>"
                          aria-valuemin="0" aria-valuemax="100">
                        </div>
                      </div>
                      <span class="fw-bold text-primary" style="min-width: 42px;"><%= row[:pct].to_s.gsub('.', ',') %>%</span>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
            <tfoot class="table-dark">
              <tr>
                <th>TOTAL</th>
                <th class="text-center"><%= @grand_total_transactions %></th>
                <th class="text-end"><%= number_to_currency(@grand_total_gross, unit: 'R$ ', separator: ',', delimiter: '.', precision: 2) %></th>
                <th class="text-end"><%= number_to_currency(@grand_total_net,   unit: 'R$ ', separator: ',', delimiter: '.', precision: 2) %></th>
                <th class="text-center">100%</th>
              </tr>
            </tfoot>
          </table>
        </div>
      <% elsif @selected_client.present? || !@current_user.admin? %>
        <div class="text-center py-5">
          <i class="bi bi-inbox display-1 text-muted"></i>
          <p class="text-muted mt-3">Nenhum dado encontrado para os filtros aplicados.</p>
        </div>
      <% else %>
        <div class="text-center py-5">
          <i class="bi bi-shop display-1 text-muted"></i>
          <p class="text-muted mt-3">Selecione um cliente para carregar o relatório.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
