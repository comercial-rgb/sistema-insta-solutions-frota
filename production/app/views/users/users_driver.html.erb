<%
breadcrumbs = [
	{active: false, href: root_path, text: t('menu.initial_page')},
	{active: false, href: users_driver_path, text: User.human_attribute_name(:driver_users)},
	{active: true, href: '#', text: t('model.list')},
]
%>

<%= 
	render 'common_pages/index',
	attributes: {
		page_title: User.human_attribute_name(:driver_users),
		url_new_path: new_user_path(profile_id: Profile::DRIVER_ID),
		policy_true: policy(User).new?,
		objects: @users,
		objects_path: users_driver_path,
		object_name: User.human_attribute_name(:driver_user),
		breadcrumbs: breadcrumbs,
		objects_path_export: users_driver_path(format: "csv", drivers_grid: (params[:drivers_grid].nil? ? "" : params[:drivers_grid].to_enum.to_h))
	}
%>
