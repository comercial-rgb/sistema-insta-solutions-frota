<% popup_notifications = Notification.popup_unread_for(@current_user) %>
<% if popup_notifications.any? %>
<% requires_ack_count = popup_notifications.count { |n| n.requires_acknowledgment } %>
<!-- Modal de Notificações Pop-up -->
<div class="modal fade" id="importantNotificationsModal" tabindex="-1" aria-labelledby="importantNotificationsModalLabel" aria-hidden="true"
     data-requires-ack-count="<%= requires_ack_count %>"
     <% if requires_ack_count > 0 %>data-bs-backdrop="static" data-bs-keyboard="false"<% end %>>
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">

            <!-- Cabeçalho -->
            <div class="modal-header bg-warning bg-opacity-10 border-warning">
                <h5 class="modal-title" id="importantNotificationsModalLabel">
                    <i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>
                    Notificações Importantes
                    <span class="badge bg-warning text-dark ms-2"><%= popup_notifications.length %></span>
                </h5>
                <% if requires_ack_count == 0 %>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                <% end %>
            </div>

            <!-- Conteúdo -->
            <div class="modal-body" style="max-height: 400px; overflow-y: auto;">
                <% popup_notifications.each do |notification| %>
                    <div class="card mb-2 border-warning notification-popup-card" id="popup-notification-<%= notification.id %>">
                        <div class="card-body py-2 px-3">
                            <div class="d-flex justify-content-between align-items-start">
                                <h6 class="card-title mb-1 fw-bold"><%= notification.title %></h6>
                                <small class="text-muted"><%= CustomHelper.get_text_date(notification.created_at, "datetime", :full) %></small>
                            </div>
                            <div class="card-text small mb-2">
                                <%= sanitize(notification.message) %>
                            </div>
                            <% if notification.requires_acknowledgment %>
                                <div class="text-end">
                                    <button type="button" class="btn btn-sm btn-outline-success acknowledge-notification-btn acknowledge-notification-required" data-notification-id="<%= notification.id %>">
                                        <i class="bi bi-check-circle me-1"></i> Ciente
                                    </button>
                                </div>
                            <% else %>
                                <div class="text-end">
                                    <button type="button" class="btn btn-sm btn-outline-secondary acknowledge-notification-btn" data-notification-id="<%= notification.id %>">
                                        <i class="bi bi-check2 me-1"></i> Entendido
                                    </button>
                                </div>
                            <% end %>
                        </div>
                    </div>
                <% end %>
            </div>

            <!-- Rodapé -->
            <div class="modal-footer">
                <a href="<%= notifications_path %>" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-bell me-1"></i> Ver todas as notificações
                </a>
                <button type="button" class="btn btn-warning btn-sm" id="closePopupNotifications"
                        <% if requires_ack_count > 0 %>disabled<% end %>>
                    <i class="bi bi-check2-all me-1"></i> Fechar
                </button>
            </div>

        </div>
    </div>
</div>
<% end %>
