<% if !@order_service_status.nil? %>
    <div class="row">
        <div class="col-12 d-flex gap-2 flex-wrap">
            <% if order_service_status.id == OrderServiceStatus::NOTA_FISCAL_INSERIDA_ID && (@current_user.admin? || ((@current_user.manager? || @current_user.additional?))) %>
                <button type="button" class="px-2 btn btn-sm btn-primary action-to-order-services-listing" id="authorize-order-services">
                    <%= OrderService.human_attribute_name(:authorize_order_services) %>
                </button>
            <% elsif order_service_status.id == OrderServiceStatus::AUTORIZADA_ID && @current_user.admin? %>
                <button type="button" class="px-2 btn btn-sm btn-primary action-to-order-services-listing" id="waiting-payment-order-services">
                    <%= OrderService.human_attribute_name(:waiting_payment) %>
                </button>
            <% elsif order_service_status.id == OrderServiceStatus::AGUARDANDO_PAGAMENTO_ID && @current_user.admin? %>
                <button type="button" class="px-2 btn btn-sm btn-primary action-to-order-services-listing" id="make-payment-order-services">
                    <%= OrderService.human_attribute_name(:make_payment) %>
                </button>
            <% end %>

            <!-- Download em lote de PDF -->
            <button type="button" class="px-2 btn btn-sm btn-danger" id="batch-print-os-btn" title="Baixar PDFs selecionados em um único arquivo">
                <i class="bi bi-file-earmark-pdf me-1"></i> Download PDF em Lote
            </button>
        </div>
    </div>

    <!-- Form oculto para o batch print -->
    <form id="batch-print-form" action="<%= batch_print_order_services_path %>" method="post" target="_blank" style="display: none;">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <div id="batch-print-ids"></div>
    </form>

    <script>
    document.addEventListener('DOMContentLoaded', function() {
        var batchBtn = document.getElementById('batch-print-os-btn');
        if (batchBtn) {
            batchBtn.addEventListener('click', function() {
                var checked = document.querySelectorAll('.select-order-service:checked');
                if (checked.length === 0) {
                    // Se nenhum checkbox selecionado, pegar todos os IDs visíveis da tabela
                    var allRows = document.querySelectorAll('table tbody tr[data-os-id]');
                    if (allRows.length === 0) {
                        alert('Nenhuma OS encontrada para download. Selecione ao menos uma OS.');
                        return;
                    }
                    if (!confirm('Nenhuma OS selecionada. Deseja baixar todas as ' + allRows.length + ' OS visíveis?')) {
                        return;
                    }
                    var idsContainer = document.getElementById('batch-print-ids');
                    idsContainer.innerHTML = '';
                    allRows.forEach(function(row) {
                        var input = document.createElement('input');
                        input.type = 'hidden';
                        input.name = 'order_service_ids[]';
                        input.value = row.getAttribute('data-os-id');
                        idsContainer.appendChild(input);
                    });
                } else {
                    if (checked.length > 200) {
                        alert('Máximo de 200 OS por vez. Você selecionou ' + checked.length + '. Por favor, selecione menos.');
                        return;
                    }
                    var idsContainer = document.getElementById('batch-print-ids');
                    idsContainer.innerHTML = '';
                    checked.forEach(function(cb) {
                        var input = document.createElement('input');
                        input.type = 'hidden';
                        input.name = 'order_service_ids[]';
                        input.value = cb.value;
                        idsContainer.appendChild(input);
                    });
                }
                document.getElementById('batch-print-form').submit();
            });
        }
    });
    </script>
<% end %>

