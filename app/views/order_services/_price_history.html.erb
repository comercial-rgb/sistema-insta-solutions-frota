<% if @price_history_proposals.present? %>
  <div class="card shadow-sm mb-4 border-info">
    <div class="card-header bg-info bg-opacity-10 text-info-emphasis d-flex justify-content-between align-items-center"
         role="button" data-bs-toggle="collapse" data-bs-target="#priceHistoryCollapse" aria-expanded="true">
      <span>
        <i class="bi bi-clock-history me-2"></i>
        <strong>Histórico de preços do veículo</strong>
        <span class="badge bg-info text-dark ms-2"><%= @price_history_proposals.count %> referência(s)</span>
        <small class="text-muted ms-2">— <%= order_service.vehicle&.board %> · <%= order_service.provider_service_type&.name %></small>
      </span>
      <i class="bi bi-chevron-up"></i>
    </div>

    <div class="collapse show" id="priceHistoryCollapse">
      <div class="card-body p-3">
        <div class="alert alert-info py-2 px-3 mb-3 d-flex align-items-start gap-2" style="font-size:0.85rem;">
          <i class="bi bi-info-circle-fill mt-1 flex-shrink-0"></i>
          <span>
            Últimas <strong><%= @price_history_proposals.count %></strong> propostas aprovadas para
            <strong><%= order_service.vehicle&.board %></strong>
            com tipo de serviço <strong><%= order_service.provider_service_type&.name %></strong>.
            Utilize como referência ao avaliar as propostas atuais.
          </span>
        </div>

        <div class="row g-3">
          <% @price_history_proposals.each do |proposal| %>
            <div class="col-md-4">
              <div class="card h-100 border-secondary shadow-sm">
                <div class="card-header py-2 px-3 bg-light d-flex justify-content-between align-items-start">
                  <div>
                    <span class="fw-semibold text-primary" style="font-size:0.9rem;">
                      <%= proposal.order_service&.code %>
                    </span>
                    <span class="badge ms-1" style="font-size:0.65rem;
                      background-color:<%= proposal.order_service_proposal_status_id == OrderServiceProposalStatus::PAGA_ID ? '#198754' : '#0d6efd' %>;">
                      <%= proposal.order_service_proposal_status&.name %>
                    </span>
                  </div>
                  <small class="text-muted"><%= proposal.created_at.strftime('%d/%m/%Y') %></small>
                </div>
                <div class="card-body py-2 px-3">
                  <p class="mb-2 text-muted" style="font-size:0.8rem;">
                    <i class="bi bi-building me-1"></i><%= proposal.provider&.get_name || '—' %>
                  </p>

                  <% pecas = proposal.order_service_proposal_items.reject(&:is_complement).select { |i| (i.get_category_id || 1) == 1 } %>
                  <% servicos = proposal.order_service_proposal_items.reject(&:is_complement).select { |i| (i.get_category_id || 1) != 1 } %>

                  <% if pecas.any? %>
                    <p class="mb-1 fw-semibold text-secondary" style="font-size:0.75rem;">PEÇAS</p>
                    <% pecas.each do |item| %>
                      <div class="d-flex justify-content-between mb-1" style="font-size:0.8rem;">
                        <span class="text-truncate me-2" style="max-width:65%;" title="<%= item.service_name %>">
                          <%= item.service_name %>
                          <% if item.brand.present? %>
                            <small class="text-muted">(<!-- <%= item.brand %> -->)</small>
                          <% end %>
                        </span>
                        <span class="fw-semibold text-nowrap">
                          <%= number_to_currency(item.unity_value, unit: 'R$ ', separator: ',', delimiter: '.') %>
                          <small class="text-muted">x<%= item.quantity %></small>
                        </span>
                      </div>
                    <% end %>
                  <% end %>

                  <% if servicos.any? %>
                    <p class="mb-1 fw-semibold text-secondary mt-2" style="font-size:0.75rem;">SERVIÇOS</p>
                    <% servicos.each do |item| %>
                      <div class="d-flex justify-content-between mb-1" style="font-size:0.8rem;">
                        <span class="text-truncate me-2" style="max-width:65%;" title="<%= item.service_name %>">
                          <%= item.service_name %>
                        </span>
                        <span class="fw-semibold text-nowrap">
                          <%= number_to_currency(item.unity_value, unit: 'R$ ', separator: ',', delimiter: '.') %>
                          <small class="text-muted">x<%= item.quantity %></small>
                        </span>
                      </div>
                    <% end %>
                  <% end %>

                  <% if pecas.empty? && servicos.empty? %>
                    <p class="text-muted mb-0" style="font-size:0.8rem;">Sem itens detalhados.</p>
                  <% end %>
                </div>
                <div class="card-footer py-2 px-3 d-flex justify-content-between align-items-center bg-light">
                  <small class="text-muted">Total pago:</small>
                  <span class="fw-bold text-success">
                    <%= number_to_currency(proposal.total_value.to_f, unit: 'R$ ', separator: ',', delimiter: '.') %>
                  </span>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>
