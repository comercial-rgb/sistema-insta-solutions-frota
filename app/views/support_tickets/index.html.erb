<%
breadcrumbs = [
	{active: false, href: root_path, text: t('menu.initial_page')},
	{active: false, href: support_tickets_path, text: "Chamados"},
	{active: true, href: '#', text: t('model.list')},
]
%>

<%= 
	render 'common_pages/index',
	attributes: {
		page_title: "Chamados",
		url_new_path: new_support_ticket_path,
		policy_true: policy(SupportTicket).new?,
		objects: @support_tickets,
		objects_path: support_tickets_path,
		object_name: "Chamado",
		breadcrumbs: breadcrumbs,
		objects_path_export: support_tickets_path(format: "csv", support_tickets_grid: (params[:support_tickets_grid].nil? ? "" : params[:support_tickets_grid].to_enum.to_h))
	}
%>
