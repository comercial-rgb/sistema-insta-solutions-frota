<!-- Simulador de Precificação -->

<div class="card mb-4">
  <div class="card-body">
    <span class="badge bg-success text-uppercase mb-2">Simulador</span>
    <h5 class="card-title">Calcule seu preço mínimo antes de aceitar a operação</h5>
    <p class="text-muted">Ajuste os valores nos campos abaixo para simular diferentes cenários de precificação. O cálculo é feito automaticamente.</p>

    <div class="card bg-light p-4 mt-3">
      <div class="row g-4">
        <!-- Valor líquido desejado -->
        <div class="col-md-6">
          <label for="simLiq" class="form-label fw-semibold">Valor líquido desejado (R$)</label>
          <div class="d-flex align-items-center gap-3">
            <input type="range" class="form-range flex-grow-1" min="100" max="50000" step="50" value="850" id="simLiq">
            <span class="fw-bold fs-5" id="simLiqVal" style="min-width: 90px; text-align: right;">R$ 850</span>
          </div>
        </div>

        <!-- Taxa gerenciadora -->
        <div class="col-md-6">
          <label for="simBase" class="form-label fw-semibold">Taxa gerenciadora (%)</label>
          <div class="d-flex align-items-center gap-3">
            <input type="range" class="form-range flex-grow-1" min="0" max="15" step="0.5" value="10" id="simBase">
            <span class="fw-bold fs-5" id="simBaseVal" style="min-width: 60px; text-align: right;">10,0%</span>
          </div>
        </div>

        <!-- Desconto peça ou serviço -->
        <div class="col-md-6">
          <label for="simDesc" class="form-label fw-semibold">Desconto peça ou serviço (%)</label>
          <small class="d-block text-muted mb-1">Aplique quando o cliente possuir desconto obrigatório.</small>
          <div class="d-flex align-items-center gap-3">
            <input type="range" class="form-range flex-grow-1" min="0" max="50" step="0.5" value="0" id="simDesc">
            <span class="fw-bold fs-5" id="simDescVal" style="min-width: 60px; text-align: right;">0%</span>
          </div>
        </div>

        <!-- Taxa de antecipação -->
        <div class="col-md-6">
          <label for="simAnt" class="form-label fw-semibold">Taxa de antecipação (%)</label>
          <div class="d-flex align-items-center gap-3">
            <input type="range" class="form-range flex-grow-1" min="0" max="12" step="1" value="0" id="simAnt">
            <span class="fw-bold fs-5" id="simAntVal" style="min-width: 60px; text-align: right;">0%</span>
          </div>
        </div>

        <!-- Retenção tributária -->
        <div class="col-md-6">
          <label for="simRet" class="form-label fw-semibold">Retenção tributária (%)</label>
          <div class="d-flex align-items-center gap-3">
            <input type="range" class="form-range flex-grow-1" min="0" max="9.45" step="0.01" value="0" id="simRet">
            <span class="fw-bold fs-5" id="simRetVal" style="min-width: 60px; text-align: right;">0%</span>
          </div>
        </div>
      </div>

      <!-- Atalhos de retenção -->
      <div class="mt-3">
        <span class="small text-muted me-2">Atalhos de retenção:</span>
        <button type="button" class="btn btn-sm btn-outline-secondary me-1" onclick="document.getElementById('simRet').value=0;simCalc();">Sem retenção</button>
        <button type="button" class="btn btn-sm btn-outline-secondary me-1" onclick="document.getElementById('simRet').value=1.20;simCalc();">Estadual/Municipal Peças (1,20%)</button>
        <button type="button" class="btn btn-sm btn-outline-secondary me-1" onclick="document.getElementById('simRet').value=4.80;simCalc();">Estadual/Municipal Serviços (4,80%)</button>
        <button type="button" class="btn btn-sm btn-outline-secondary me-1" onclick="document.getElementById('simRet').value=5.85;simCalc();">Federal Peças (5,85%)</button>
        <button type="button" class="btn btn-sm btn-outline-secondary me-1" onclick="document.getElementById('simRet').value=9.45;simCalc();">Federal Serviços (9,45%)</button>
        <div class="small text-muted mt-2"><i class="bi bi-info-circle"></i> Use os atalhos acima somente se o cliente/órgão pagador realiza retenção tributária na fonte. Se o cliente for empresa privada sem retenção ou se você é optante pelo Simples Nacional, deixe em "Sem retenção".</div>
      </div>

      <!-- Resultados -->
      <div class="row g-3 mt-4">
        <div class="col-md-4">
          <div class="card text-center">
            <div class="card-body">
              <div class="small text-muted">Taxa total (gerenciadora + antecipação)</div>
              <div class="fs-3 fw-bold text-warning" id="simResTaxa">10,0%</div>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card text-center">
            <div class="card-body">
              <div class="small text-muted">Preço mínimo de venda</div>
              <div class="fs-3 fw-bold text-dark" id="simResPreco">R$ 944</div>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card text-center">
            <div class="card-body">
              <div class="small text-muted">Custo da plataforma</div>
              <div class="fs-3 fw-bold text-danger" id="simResDesc">− R$ 94</div>
            </div>
          </div>
        </div>
      </div>
      <div class="row g-3 mt-2">
        <div class="col-md-4">
          <div class="card text-center">
            <div class="card-body">
              <div class="small text-muted">Desconto peça ou serviço</div>
              <div class="fs-3 fw-bold text-primary" id="simResDescLic">R$ 0</div>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card text-center">
            <div class="card-body">
              <div class="small text-muted">Retenção (crédito fiscal)</div>
              <div class="fs-3 fw-bold text-muted" id="simResRet">R$ 0</div>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card text-center border-success">
            <div class="card-body">
              <div class="small text-muted">Líquido estimado</div>
              <div class="fs-3 fw-bold text-success" id="simResLiq">R$ 850</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Alerta -->
      <div class="mt-3" id="simAlertContainer"></div>
    </div>

    <!-- Explicação -->
    <div class="mt-4">
      <h6>Como interpretar os resultados</h6>
      <ul class="small text-muted">
        <li><strong>Taxa total</strong> = taxa gerenciadora + taxa de antecipação. É o percentual efetivamente descontado pela plataforma.</li>
        <li><strong>Preço mínimo de venda</strong> = preço de tabela que você deve cobrar na OS. Após o desconto do cliente e a taxa da plataforma, sobra exatamente o líquido desejado.</li>
        <li><strong>Custo da plataforma</strong> = valor retido pela gerenciadora (taxa gerenciadora + antecipação), calculado sobre o valor <strong>após o desconto</strong> — não sobre o preço de tabela.</li>
        <li><strong>Desconto peça ou serviço</strong> = desconto obrigatório do cliente aplicado sobre o preço de tabela. A taxa da plataforma incide apenas sobre o valor restante após este desconto.</li>
        <li><strong>Retenção tributária</strong> = valor retido pelo órgão pagador. Não é custo — é crédito fiscal recuperável via PER/DCOMP ou compensação em DARF.</li>
        <li><strong>Líquido estimado</strong> = valor que efetivamente entra no caixa do fornecedor após todos os descontos e retenções.</li>
      </ul>
    </div>
  </div>
</div>

<script>
  (function() {
    var elLiq  = document.getElementById('simLiq');
    var elBase = document.getElementById('simBase');
    var elDesc = document.getElementById('simDesc');
    var elAnt  = document.getElementById('simAnt');
    var elRet  = document.getElementById('simRet');

    function fmt(v) { return 'R$ ' + Math.round(v).toLocaleString('pt-BR'); }
    function fmtPct(v) { return parseFloat(v).toFixed(1).replace('.', ',') + '%'; }

    window.simCalc = function() {
      var liq  = parseFloat(elLiq.value);
      var base = parseFloat(elBase.value);
      var desc = parseFloat(elDesc.value);
      var ant  = parseFloat(elAnt.value);
      var ret  = parseFloat(elRet.value);
      var taxa = base + ant;

      // Cálculo: desconto primeiro, taxa incide no valor APÓS desconto
      // valorNota = preco * (1 - desc/100)
      // custoPlataforma = valorNota * taxa/100
      // retVal = valorNota * ret/100
      // liq = valorNota - custoPlataforma - retVal
      // liq = preco * (1 - desc/100) * (1 - taxa/100 - ret/100)
      var fatorDesc = 1 - desc / 100;
      var fatorLiq  = 1 - taxa / 100 - ret / 100;
      var denominador = fatorDesc * fatorLiq;
      var preco = denominador <= 0 ? 0 : liq / denominador;
      var valorNota = preco * fatorDesc;
      var descontoVal = preco - valorNota;
      var custoPlataforma = valorNota * taxa / 100;
      var retVal = valorNota * ret / 100;
      var liquidoFinal = valorNota - custoPlataforma - retVal;

      document.getElementById('simLiqVal').textContent = fmt(liq);
      document.getElementById('simBaseVal').textContent = fmtPct(base);
      document.getElementById('simDescVal').textContent = fmtPct(desc);
      document.getElementById('simAntVal').textContent = fmtPct(ant);
      document.getElementById('simRetVal').textContent = fmtPct(ret);
      document.getElementById('simResTaxa').textContent = fmtPct(taxa);
      document.getElementById('simResPreco').textContent = fmt(preco);
      document.getElementById('simResDesc').textContent = '− ' + fmt(custoPlataforma);
      document.getElementById('simResDescLic').textContent = descontoVal > 0 ? '− ' + fmt(descontoVal) : 'R$ 0';
      document.getElementById('simResRet').textContent = retVal > 0 ? fmt(retVal) : 'R$ 0';
      document.getElementById('simResLiq').textContent = fmt(liquidoFinal);

      var alertContainer = document.getElementById('simAlertContainer');

      if (denominador <= 0) {
        alertContainer.innerHTML = '<div class="alert alert-danger mb-0"><strong>Erro:</strong> a combinação de desconto, taxa e retenção inviabiliza a operação. Nenhum preço é viável.</div>';
      } else if (liquidoFinal < liq * 0.85) {
        alertContainer.innerHTML = '<div class="alert alert-danger mb-0"><strong>Atenção:</strong> com a retenção tributária, seu líquido final será ' + fmt(liquidoFinal) + '. Lembre-se: a retenção é crédito fiscal recuperável — não é perda definitiva.</div>';
      } else if (taxa + desc >= 25) {
        alertContainer.innerHTML = '<div class="alert alert-warning mb-0"><strong>Atenção:</strong> desconto + taxa acima de 25%. Revise o preço de venda antes de aceitar esta ordem.</div>';
      } else if (taxa === 0 && desc === 0) {
        alertContainer.innerHTML = '<div class="alert alert-success mb-0">Sem taxas nem desconto aplicados. Operação com custo zero.</div>';
      } else {
        alertContainer.innerHTML = '';
      }
    };

    [elLiq, elBase, elDesc, elAnt, elRet].forEach(function(el) {
      el.addEventListener('input', window.simCalc);
    });

    window.simCalc();
  })();
</script>
