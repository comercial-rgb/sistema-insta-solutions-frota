<%
breadcrumbs = [
  {active: false, href: root_path, text: t('menu.initial_page')},
  {active: false, href: faturamento_index_path, text: 'Faturamento'},
  {active: true, href: '#', text: "Fatura #{@fatura.numero}"},
]
%>

<div class="container-fluid">
  <%= render 'common_pages/breadcrumb', links: breadcrumbs %>

  <!-- Back button -->
  <div class="mb-3">
    <%= link_to faturamento_index_path, class: 'btn btn-outline-secondary btn-sm' do %>
      <i class="bi bi-arrow-left"></i> Voltar às faturas
    <% end %>
  </div>

  <!-- Header Card -->
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
      <div class="row align-items-start">
        <div class="col-md-8">
          <h3 class="text-primary mb-1">Fatura <%= @fatura.numero %></h3>
          <p class="text-muted mb-1">Emissão: <%= @fatura.data_emissao&.strftime('%d/%m/%Y') %></p>
          <% if @fatura.data_vencimento %>
            <p class="mb-0 <%= @fatura.vencida? ? 'text-danger fw-bold' : 'text-muted' %>">
              <i class="bi bi-calendar-event"></i>
              Vencimento: <%= @fatura.data_vencimento.strftime('%d/%m/%Y') %>
              <%= ' — VENCIDA!' if @fatura.vencida? %>
            </p>
          <% end %>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
          <%= render 'faturamento/shared/status_badge', status: @fatura.status %>
        </div>
      </div>
    </div>
  </div>

  <!-- Detail Blocks -->
  <div class="row g-3 mb-4">
    <!-- Fornecedor -->
    <div class="col-md-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <h6 class="text-uppercase small text-muted mb-2">
            <i class="bi bi-truck"></i> Fornecedor
          </h6>
          <div style="line-height:1.8">
            <strong><%= @fatura.provider&.name || '-' %></strong><br>
            <% if @fatura.provider&.cnpj.present? %>
              CNPJ: <%= @fatura.provider.cnpj %>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Centro de Custo -->
    <div class="col-md-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <h6 class="text-uppercase small text-muted mb-2">
            <i class="bi bi-wallet2"></i> Centro de Custo
          </h6>
          <div style="line-height:1.8">
            <strong><%= @fatura.cost_center&.name || '-' %></strong>
          </div>
        </div>
      </div>
    </div>

    <!-- Resumo Financeiro -->
    <div class="col-md-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <h6 class="text-uppercase small text-muted mb-2">
            <i class="bi bi-cash-stack"></i> Resumo Financeiro
          </h6>
          <div style="line-height:1.8">
            <strong class="text-success">Valor Bruto: <%= number_to_currency(@fatura.valor_bruto, unit: 'R$ ') %></strong><br>
            <span class="text-warning">
              Retenções: -<%= number_to_currency(@fatura.total_retencoes, unit: 'R$ ') %>
            </span><br>
            <span class="text-danger">
              Taxa Admin: -<%= number_to_currency(@fatura.taxa_administracao, unit: 'R$ ') %>
            </span><br>
            <hr class="my-1">
            <strong class="text-primary">
              Valor Final: <%= number_to_currency(@fatura.valor_final, unit: 'R$ ') %>
            </strong>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- NF Info -->
  <% if @fatura.nota_fiscal_numero.present? %>
    <div class="alert alert-info border-0 shadow-sm">
      <i class="bi bi-file-earmark-text me-2"></i>
      NF Nº: <strong><%= @fatura.nota_fiscal_numero %></strong>
      <% if @fatura.nota_fiscal_serie.present? %>
        | Série: <%= @fatura.nota_fiscal_serie %>
      <% end %>
    </div>
  <% end %>

  <!-- Itens da Fatura -->
  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-bottom">
      <h6 class="mb-0 fw-bold">
        <i class="bi bi-list-ul me-1"></i>
        Itens da Fatura (<%= @fatura.fatura_itens.count %>)
      </h6>
    </div>
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th class="text-uppercase small text-muted">Descrição</th>
            <th class="text-uppercase small text-muted">Tipo</th>
            <th class="text-uppercase small text-muted">Veículo</th>
            <th class="text-uppercase small text-muted">OS</th>
            <th class="text-uppercase small text-muted">Qtd</th>
            <th class="text-uppercase small text-muted">Valor</th>
            <th class="text-uppercase small text-muted">C.Custo</th>
          </tr>
        </thead>
        <tbody>
          <% @fatura.fatura_itens.each do |item| %>
            <tr>
              <td><%= item.descricao || '-' %></td>
              <td>
                <% tipo_color = { 'servico' => 'primary', 'peca' => 'success', 'outro' => 'secondary' } %>
                <span class="badge bg-<%= tipo_color[item.tipo] || 'secondary' %>">
                  <%= item.tipo&.capitalize %>
                </span>
              </td>
              <td><strong><%= item.veiculo_placa || '-' %></strong></td>
              <td>
                <% if item.order_service_id %>
                  <%= link_to "##{item.order_service_id}", order_service_path(item.order_service_id), class: 'text-decoration-none' %>
                <% else %>
                  -
                <% end %>
              </td>
              <td><%= item.quantidade %></td>
              <td><%= number_to_currency(item.valor, unit: 'R$ ') %></td>
              <td><%= item.centro_custo_nome || '-' %></td>
            </tr>
          <% end %>
          <% if @fatura.fatura_itens.empty? %>
            <tr>
              <td colspan="7" class="text-center text-muted py-4">Nenhum item nesta fatura</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Observações -->
  <% if @fatura.observacoes.present? %>
    <div class="card border-0 shadow-sm mt-3">
      <div class="card-body">
        <h6 class="mb-2"><i class="bi bi-chat-text me-1"></i> Observações</h6>
        <p class="text-muted mb-0"><%= @fatura.observacoes %></p>
      </div>
    </div>
  <% end %>

  <% if @fatura.admin_observacoes.present? %>
    <div class="card border-0 shadow-sm mt-3">
      <div class="card-body">
        <h6 class="mb-2"><i class="bi bi-shield-lock me-1"></i> Observações Admin</h6>
        <p class="text-muted mb-0"><%= @fatura.admin_observacoes %></p>
      </div>
    </div>
  <% end %>
</div>
