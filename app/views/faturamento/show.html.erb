<%
breadcrumbs = [
  {active: false, href: root_path, text: t('menu.initial_page')},
  {active: false, href: faturamento_index_path, text: 'Faturamento'},
  {active: true, href: '#', text: "Fatura #{@fatura.numero}"},
]
%>

<div class="container-fluid">
  <%= render 'common_pages/breadcrumb', links: breadcrumbs %>

  <!-- Back button -->
  <div class="mb-3">
    <%= link_to faturamento_index_path, class: 'btn btn-outline-secondary btn-sm' do %>
      <i class="bi bi-arrow-left"></i> Voltar às faturas
    <% end %>
  </div>

  <!-- Header Card -->
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
      <div class="row align-items-start">
        <div class="col-md-8">
          <h3 class="text-primary mb-1">Fatura <%= @fatura.numero %></h3>
          <p class="text-muted mb-1">
            <span class="badge bg-light text-dark border me-1">Peças: <%= @fatura.numero_pecas || "#{@fatura.numero}-P" %></span>
            <span class="badge bg-light text-dark border">Serviços: <%= @fatura.numero_servicos || "#{@fatura.numero}-S" %></span>
          </p>
          <p class="text-muted mb-1">Emissão: <%= @fatura.data_emissao&.strftime('%d/%m/%Y') %></p>
          <% if @fatura.data_vencimento %>
            <p class="mb-0 <%= @fatura.vencida? ? 'text-danger fw-bold' : 'text-muted' %>">
              <i class="bi bi-calendar-event"></i>
              Vencimento: <%= @fatura.data_vencimento.strftime('%d/%m/%Y') %>
              <%= " — VENCIDA há #{@fatura.dias_vencida} dia(s)!" if @fatura.vencida? %>
            </p>
          <% end %>
          <% if @fatura.data_pagamento.present? %>
            <p class="mb-0 text-success"><i class="bi bi-check-circle-fill"></i> Pago em: <%= @fatura.data_pagamento.strftime('%d/%m/%Y') %></p>
          <% end %>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
          <%= render 'faturamento/shared/status_badge', status: @fatura.status %>
          <div class="mt-2 d-flex flex-wrap gap-1 justify-content-md-end">
            <div class="btn-group">
              <a href="<%= gerar_pdf_faturamento_path(@fatura) %>" class="btn btn-sm btn-outline-danger">
                <i class="bi bi-file-earmark-pdf"></i> PDF
              </a>
              <button type="button" class="btn btn-sm btn-outline-danger dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown"></button>
              <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="<%= gerar_pdf_faturamento_path(@fatura) %>"><i class="bi bi-files me-1"></i> Completo</a></li>
                <li><a class="dropdown-item" href="<%= gerar_pdf_faturamento_path(@fatura, split: 'pecas') %>"><i class="bi bi-tools me-1"></i> Somente Peças</a></li>
                <li><a class="dropdown-item" href="<%= gerar_pdf_faturamento_path(@fatura, split: 'servicos') %>"><i class="bi bi-wrench me-1"></i> Somente Serviços</a></li>
              </ul>
            </div>
            <div class="btn-group">
              <a href="<%= gerar_docx_faturamento_path(@fatura) %>" class="btn btn-sm btn-outline-success">
                <i class="bi bi-file-earmark-word"></i> Word
              </a>
              <button type="button" class="btn btn-sm btn-outline-success dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown"></button>
              <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="<%= gerar_docx_faturamento_path(@fatura) %>"><i class="bi bi-files me-1"></i> Completo</a></li>
                <li><a class="dropdown-item" href="<%= gerar_docx_faturamento_path(@fatura, split: 'pecas') %>"><i class="bi bi-tools me-1"></i> Somente Peças</a></li>
                <li><a class="dropdown-item" href="<%= gerar_docx_faturamento_path(@fatura, split: 'servicos') %>"><i class="bi bi-wrench me-1"></i> Somente Serviços</a></li>
              </ul>
            </div>
            <a href="<%= gerar_excel_faturamento_path(@fatura) %>" class="btn btn-sm btn-outline-primary">
              <i class="bi bi-file-earmark-spreadsheet"></i> Excel
            </a>
            <% if @current_user.admin? && %w[aberta enviada].include?(@fatura.status) %>
              <button class="btn btn-sm btn-success" onclick="Faturamento.marcarPago(<%= @fatura.id %>)">
                <i class="bi bi-check-circle-fill"></i> Marcar como Pago
              </button>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Detail Blocks -->
  <div class="row g-3 mb-4">
    <!-- Cliente -->
    <div class="col-md-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <h6 class="text-uppercase small text-muted mb-2">
            <i class="bi bi-building"></i> Cliente
          </h6>
          <div style="line-height:1.8">
            <strong><%= @fatura.client&.fantasy_name.presence || @fatura.client&.social_name.presence || @fatura.client&.name || '-' %></strong><br>
            <% if @fatura.client&.cnpj.present? %>
              CNPJ: <%= @fatura.client.cnpj %><br>
            <% end %>
            <% if @fatura.client&.phone.present? %>
              <i class="bi bi-telephone"></i> <%= @fatura.client.phone %><br>
            <% end %>
            <% if @fatura.client&.email.present? %>
              <i class="bi bi-envelope"></i> <%= @fatura.client.email %>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Centro de Custo -->
    <div class="col-md-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <h6 class="text-uppercase small text-muted mb-2">
            <i class="bi bi-wallet2"></i> Centro de Custo
          </h6>
          <div style="line-height:1.8">
            <strong><%= @fatura.cost_center&.name || '-' %></strong>
          </div>
        </div>
      </div>
    </div>

    <!-- Resumo Financeiro -->
    <div class="col-md-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <h6 class="text-uppercase small text-muted mb-2">
            <i class="bi bi-cash-stack"></i> Resumo Financeiro
          </h6>
          <table class="table table-sm table-borderless mb-0" style="line-height:1.6">
            <tbody>
              <tr>
                <td class="text-muted">Valor Bruto:</td>
                <td class="text-end fw-bold text-success"><%= number_to_currency(@fatura.valor_bruto, unit: 'R$ ') %></td>
              </tr>
              <% if @fatura.desconto.to_f > 0 %>
                <tr>
                  <td class="text-muted">(-) Desconto:</td>
                  <td class="text-end text-info">-<%= number_to_currency(@fatura.desconto, unit: 'R$ ') %></td>
                </tr>
              <% end %>
              <tr>
                <td class="text-muted">(-) Retenções:</td>
                <td class="text-end text-warning">-<%= number_to_currency(@fatura.total_retencoes, unit: 'R$ ') %></td>
              </tr>
              <tr>
                <td class="text-muted">(-) Taxa Admin:</td>
                <td class="text-end text-danger">-<%= number_to_currency(@fatura.taxa_administracao, unit: 'R$ ') %></td>
              </tr>
              <tr class="border-top">
                <td class="fw-bold text-primary">Valor Líquido:</td>
                <td class="text-end fw-bold text-primary"><%= number_to_currency(@fatura.valor_liquido, unit: 'R$ ') %></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- Contrato / Empenhos -->
  <%
    contract = @fatura.contract
    unless contract
      contract = @fatura.fatura_itens.includes(order_service: [:commitment, :commitment_parts, :commitment_services])
        .map { |i| i.order_service }.compact.flat_map { |os|
          [os.commitment, os.commitment_parts, os.commitment_services].compact
        }.map(&:contract).compact.first
    end
  %>
  <% if contract %>
    <%
      saldo_total = contract.respond_to?(:get_total_value) ? contract.get_total_value.to_f : contract.total_value.to_f
      saldo_usado = contract.respond_to?(:get_used_value) ? contract.get_used_value.to_f : 0
      saldo_disponivel = contract.respond_to?(:get_disponible_value) ? contract.get_disponible_value.to_f : (saldo_total - saldo_usado)

      empenhos = @fatura.fatura_itens.includes(order_service: [:commitment, :commitment_parts, :commitment_services])
        .map { |i| i.order_service }.compact.flat_map { |os|
          [os.commitment, os.commitment_parts, os.commitment_services].compact
        }.uniq(&:id)
    %>
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white border-bottom">
        <h6 class="mb-0 fw-bold"><i class="bi bi-file-earmark-text me-1"></i> Contrato / Empenhos</h6>
      </div>
      <div class="card-body">
        <div class="row mb-3">
          <div class="col-md-3">
            <small class="text-muted d-block">Contrato Nº</small>
            <strong><%= contract.number || '-' %></strong>
          </div>
          <div class="col-md-3">
            <small class="text-muted d-block">Valor Total</small>
            <strong><%= number_to_currency(saldo_total, unit: 'R$ ') %></strong>
          </div>
          <div class="col-md-3">
            <small class="text-muted d-block">Saldo Consumido</small>
            <strong class="text-warning"><%= number_to_currency(saldo_usado, unit: 'R$ ') %></strong>
          </div>
          <div class="col-md-3">
            <small class="text-muted d-block">Saldo Disponível</small>
            <strong class="text-success"><%= number_to_currency(saldo_disponivel, unit: 'R$ ') %></strong>
          </div>
        </div>
        <% if empenhos.any? %>
          <h6 class="fw-bold small text-muted mb-2">Empenhos Vinculados</h6>
          <table class="table table-sm table-bordered mb-0">
            <thead class="table-light">
              <tr>
                <th class="text-uppercase small text-muted">Empenho Nº</th>
                <th class="text-uppercase small text-muted text-end">Saldo Inicial</th>
                <th class="text-uppercase small text-muted text-end">Consumido</th>
                <th class="text-uppercase small text-muted text-end">Restante</th>
              </tr>
            </thead>
            <tbody>
              <% empenhos.each do |emp| %>
                <%
                  saldo_ini = Commitment.respond_to?(:sum_budget_value) ? Commitment.sum_budget_value(emp).to_f : emp.commitment_value.to_f
                  consumido = Commitment.respond_to?(:get_total_already_consumed_value) ? Commitment.get_total_already_consumed_value(emp).to_f : 0
                  restante = emp.respond_to?(:get_available_balance) ? emp.get_available_balance.to_f : (saldo_ini - consumido)
                %>
                <tr>
                  <td><%= emp.commitment_number || '-' %></td>
                  <td class="text-end"><%= number_to_currency(saldo_ini, unit: 'R$ ') %></td>
                  <td class="text-end text-warning"><%= number_to_currency(consumido, unit: 'R$ ') %></td>
                  <td class="text-end text-success"><%= number_to_currency(restante, unit: 'R$ ') %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white border-bottom">
        <h6 class="mb-0 fw-bold"><i class="bi bi-file-earmark-text me-1"></i> Contrato / Empenhos</h6>
      </div>
      <div class="card-body">
        <p class="text-muted mb-0">Nenhum contrato vinculado a esta fatura.</p>
      </div>
    </div>
  <% end %>

  <!-- NF Info -->
  <% has_nf = @fatura.nota_fiscal_numero.present? || @fatura.nota_fiscal_numero_pecas.present? || @fatura.nota_fiscal_numero_servicos.present? || @fatura.nota_fiscal_pecas_file.attached? || @fatura.nota_fiscal_servicos_file.attached? %>
  <% if has_nf %>
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white border-bottom">
        <h6 class="mb-0 fw-bold"><i class="bi bi-file-earmark-text me-1"></i> Dados da Nota Fiscal</h6>
      </div>
      <div class="card-body">
        <% if @fatura.nota_fiscal_numero.present? %>
        <div class="row">
          <div class="col-md-3">
            <small class="text-muted d-block">N° Nota Fiscal (consolidado)</small>
            <strong><%= @fatura.nota_fiscal_numero %></strong>
          </div>
          <div class="col-md-2">
            <small class="text-muted d-block">Série</small>
            <strong><%= @fatura.nota_fiscal_serie.presence || '-' %></strong>
          </div>
          <div class="col-md-2">
            <small class="text-muted d-block">Emissão</small>
            <strong><%= @fatura.data_emissao&.strftime('%d/%m/%Y') || '-' %></strong>
          </div>
          <div class="col-md-2">
            <small class="text-muted d-block">Valor Bruto</small>
            <strong><%= number_to_currency(@fatura.valor_bruto, unit: 'R$ ') %></strong>
          </div>
          <div class="col-md-3">
            <small class="text-muted d-block">Valor Líquido</small>
            <strong class="text-primary"><%= number_to_currency(@fatura.valor_liquido, unit: 'R$ ') %></strong>
          </div>
        </div>
        <% end %>
        <div class="row mt-3">
          <div class="col-md-6 border-end">
            <h6 class="text-muted mb-2"><i class="bi bi-gear me-1"></i> NF de Peças <span class="badge bg-light text-dark ms-1"><%= @fatura.numero_pecas || "#{@fatura.numero}-P" %></span></h6>
            <div class="row">
              <div class="col-md-6">
                <small class="text-muted d-block">N°</small>
                <strong><%= @fatura.nota_fiscal_numero_pecas.presence || '-' %></strong>
              </div>
              <div class="col-md-6">
                <small class="text-muted d-block">Série</small>
                <strong><%= @fatura.nota_fiscal_serie_pecas.presence || '-' %></strong>
              </div>
            </div>
            <div class="mt-2">
              <small class="text-muted d-block">Arquivo anexado</small>
              <% if @fatura.nota_fiscal_pecas_file.attached? %>
                <%= link_to "<i class='bi bi-download'></i> #{@fatura.nota_fiscal_pecas_file.filename}".html_safe, rails_blob_path(@fatura.nota_fiscal_pecas_file, disposition: 'attachment'), class: 'btn btn-sm btn-outline-primary' %>
              <% else %>
                <span class="text-muted">Nenhum</span>
              <% end %>
            </div>
          </div>
          <div class="col-md-6">
            <h6 class="text-muted mb-2"><i class="bi bi-tools me-1"></i> NF de Serviços <span class="badge bg-light text-dark ms-1"><%= @fatura.numero_servicos || "#{@fatura.numero}-S" %></span></h6>
            <div class="row">
              <div class="col-md-6">
                <small class="text-muted d-block">N°</small>
                <strong><%= @fatura.nota_fiscal_numero_servicos.presence || '-' %></strong>
              </div>
              <div class="col-md-6">
                <small class="text-muted d-block">Série</small>
                <strong><%= @fatura.nota_fiscal_serie_servicos.presence || '-' %></strong>
              </div>
            </div>
            <div class="mt-2">
              <small class="text-muted d-block">Arquivo anexado</small>
              <% if @fatura.nota_fiscal_servicos_file.attached? %>
                <%= link_to "<i class='bi bi-download'></i> #{@fatura.nota_fiscal_servicos_file.filename}".html_safe, rails_blob_path(@fatura.nota_fiscal_servicos_file, disposition: 'attachment'), class: 'btn btn-sm btn-outline-primary' %>
              <% else %>
                <span class="text-muted">Nenhum</span>
              <% end %>
            </div>
          </div>
        </div>
        <div class="row mt-3">
          <div class="col-md-3">
            <small class="text-muted d-block">Desconto</small>
            <strong><%= number_to_currency(@fatura.desconto || 0, unit: 'R$ ') %></strong>
          </div>
          <div class="col-md-3">
            <small class="text-muted d-block">Retenções</small>
            <strong class="text-warning"><%= number_to_currency(@fatura.total_retencoes, unit: 'R$ ') %></strong>
          </div>
          <div class="col-md-3">
            <small class="text-muted d-block">Data de Vencimento</small>
            <strong class="<%= @fatura.vencida? ? 'text-danger' : '' %>">
              <%= @fatura.data_vencimento&.strftime('%d/%m/%Y') || '-' %>
            </strong>
          </div>
          <div class="col-md-3">
            <small class="text-muted d-block">Status</small>
            <%= render 'faturamento/shared/status_badge', status: @fatura.status %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Itens da Fatura -->
  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-bottom">
      <h6 class="mb-0 fw-bold">
        <i class="bi bi-list-ul me-1"></i>
        Itens da Fatura (<%= @fatura.fatura_itens.count %>)
      </h6>
    </div>
    <div class="table-responsive">
      <table class="table table-sm table-bordered mb-0">
        <thead class="table-light">
          <tr>
            <th class="text-uppercase small text-muted">OS</th>
            <th class="text-uppercase small text-muted">Fornecedor</th>
            <th class="text-uppercase small text-muted">Veículo</th>
            <th class="text-uppercase small text-muted">C.Custo</th>
            <th class="text-uppercase small text-muted text-end">Vl. Peças (NF)</th>
            <th class="text-uppercase small text-muted text-end">Vl. Serviços (NF)</th>
            <th class="text-uppercase small text-muted text-end">Valor Bruto</th>
            <th class="text-uppercase small text-muted text-end">Desc.</th>
            <th class="text-uppercase small text-muted text-end">V. c/ Desc.</th>
          </tr>
        </thead>
        <tbody>
          <%
            total_pecas_bruto = 0
            total_servicos_bruto = 0
            total_bruto = 0
            total_desconto_itens = 0
            total_com_desconto = 0
            client_discount_pct = (@fatura.client&.discount_percent || 0).to_d / 100
          %>
          <% @fatura.fatura_itens.select { |i| i.order_service_id.present? }.group_by(&:order_service_id).each do |os_id, items| %>
            <%
              os = items.first.order_service
              next unless os

              proposal = os.order_service_proposals
                .select { |p| [OrderServiceProposalStatus::AUTORIZADA_ID,
                               OrderServiceProposalStatus::APROVADA_ID,
                               OrderServiceProposalStatus::NOTAS_INSERIDAS_ID,
                               OrderServiceProposalStatus::AGUARDANDO_PAGAMENTO_ID,
                               OrderServiceProposalStatus::PAGA_ID].compact.include?(p.order_service_proposal_status_id) }
                .reject { |p| p.is_complement }
                .sort_by { |p| p.updated_at }.last

              next unless proposal

              invoices = proposal.order_service_invoices.to_a
              nf_pecas = invoices.select { |i| i.order_service_invoice_type_id == OrderServiceInvoiceType::PECAS_ID }
              nf_servicos = invoices.select { |i| i.order_service_invoice_type_id == OrderServiceInvoiceType::SERVICOS_ID }

              pecas_val = nf_pecas.sum(&:value).to_f
              servicos_val = nf_servicos.sum(&:value).to_f
              bruto = proposal.total_value_without_discount.to_f
              desc_val = (bruto * client_discount_pct).to_f
              com_desc = bruto - desc_val

              pecas_nums = nf_pecas.map(&:number).compact.join(', ')
              servicos_nums = nf_servicos.map(&:number).compact.join(', ')

              provider = proposal.provider
              is_simples = provider ? !provider.optante_simples : true

              total_pecas_bruto += pecas_val
              total_servicos_bruto += servicos_val
              total_bruto += bruto
              total_desconto_itens += desc_val
              total_com_desconto += com_desc

              pct_desc_os = bruto > 0 ? ((desc_val / bruto) * 100) : 0
            %>
            <tr>
              <td><strong>#<%= os.code %></strong></td>
              <td>
                <small><%= provider&.get_name&.truncate(30) || '-' %></small>
                <% if is_simples %>
                  <span class="badge bg-success" style="font-size:0.6em;">Simples</span>
                <% else %>
                  <span class="badge bg-warning text-dark" style="font-size:0.6em;">Não-Simples</span>
                <% end %>
              </td>
              <td><%= os.vehicle&.board || '-' %></td>
              <td><%= os.cost_center&.name || '-' %></td>
              <td class="text-end">
                <%= number_to_currency(pecas_val, unit: 'R$ ') %>
                <% if pecas_nums.present? %>
                  <br><small class="text-muted">(NF <%= pecas_nums %>)</small>
                <% end %>
              </td>
              <td class="text-end">
                <%= number_to_currency(servicos_val, unit: 'R$ ') %>
                <% if servicos_nums.present? %>
                  <br><small class="text-muted">(NF <%= servicos_nums %>)</small>
                <% end %>
              </td>
              <td class="text-end"><%= number_to_currency(bruto, unit: 'R$ ') %></td>
              <td class="text-end text-danger">
                - <%= number_to_currency(desc_val, unit: 'R$ ') %>
                <small class="text-muted">(<%= number_with_precision(pct_desc_os, precision: 2) %>%)</small>
              </td>
              <td class="text-end text-success fw-bold"><%= number_to_currency(com_desc, unit: 'R$ ') %></td>
            </tr>
            <tr style="background:#f8f9fa; font-size:0.8em;">
              <td colspan="9" class="py-1 ps-4 text-muted">
                <i class="bi bi-person-vcard me-1"></i>
                <strong>CNPJ:</strong> <%= provider&.cnpj || '-' %>
                &nbsp;|&nbsp; <strong>Regime:</strong> <%= is_simples ? 'Simples Nacional (Isento de Retenção)' : 'Não-Simples (Retenção Aplicável)' %>
              </td>
            </tr>
          <% end %>
          <% if @fatura.fatura_itens.empty? %>
            <tr>
              <td colspan="9" class="text-center text-muted py-4">Nenhum item nesta fatura</td>
            </tr>
          <% else %>
            <tr class="table-light fw-bold">
              <td colspan="4" class="text-end">SUBTOTAIS:</td>
              <td class="text-end"><%= number_to_currency(total_pecas_bruto, unit: 'R$ ') %></td>
              <td class="text-end"><%= number_to_currency(total_servicos_bruto, unit: 'R$ ') %></td>
              <td class="text-end"><%= number_to_currency(total_bruto, unit: 'R$ ') %></td>
              <td class="text-end text-danger">- <%= number_to_currency(total_desconto_itens, unit: 'R$ ') %></td>
              <td class="text-end text-success"><%= number_to_currency(total_com_desconto, unit: 'R$ ') %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Observações -->
  <% if @fatura.observacoes.present? %>
    <div class="card border-0 shadow-sm mt-3">
      <div class="card-body">
        <h6 class="mb-2"><i class="bi bi-chat-text me-1"></i> Observações</h6>
        <p class="text-muted mb-0"><%= @fatura.observacoes %></p>
      </div>
    </div>
  <% end %>

  <% if @fatura.admin_observacoes.present? %>
    <div class="card border-0 shadow-sm mt-3">
      <div class="card-body">
        <h6 class="mb-2"><i class="bi bi-shield-lock me-1"></i> Observações Admin</h6>
        <p class="text-muted mb-0"><%= @fatura.admin_observacoes %></p>
      </div>
    </div>
  <% end %>
</div>
