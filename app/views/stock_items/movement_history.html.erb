<%
breadcrumbs = [
  {active: false, href: root_path, text: t('menu.initial_page')},
  {active: false, href: stock_items_path, text: 'Estoque'},
  {active: false, href: stock_item_path(@stock_item), text: @stock_item.formatted_name},
  {active: true, href: '#', text: 'Histórico de Movimentações'},
]
%>

<div class="container-fluid">
  <%= render 'common_pages/breadcrumb', links: breadcrumbs %>

  <div class="row mb-3">
    <div class="col-12 d-flex justify-content-between align-items-center">
      <h4 class="mb-0">
        <i class="bi bi-clock-history me-2"></i>Movimentações - <%= @stock_item.formatted_name %>
      </h4>
      <%= link_to stock_item_path(@stock_item), class: 'btn btn-secondary btn-sm' do %>
        <i class="bi bi-arrow-left"></i> Voltar
      <% end %>
    </div>
  </div>

  <div class="card shadow-sm">
    <div class="card-body">
      <% if @movements.any? %>
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Data</th>
                <th>Tipo</th>
                <th>Quantidade</th>
                <th>Saldo Após</th>
                <th>Preço Unit.</th>
                <th>Origem</th>
                <th>Documento</th>
                <th>Fornecedor</th>
                <th>Usuário</th>
                <th>Motivo</th>
              </tr>
            </thead>
            <tbody>
              <% @movements.each do |movement| %>
                <tr>
                  <td><%= movement.created_at.strftime('%d/%m/%Y %H:%M') %></td>
                  <td>
                    <span class="badge <%= movement.is_entry? ? 'bg-success' : 'bg-danger' %>">
                      <%= movement.movement_type_label %>
                    </span>
                  </td>
                  <td class="<%= movement.is_entry? ? 'text-success' : 'text-danger' %> fw-bold">
                    <%= movement.is_entry? ? '+' : '-' %><%= movement.quantity %>
                  </td>
                  <td><%= movement.balance_after %></td>
                  <td><%= movement.unit_price.present? ? number_to_currency(movement.unit_price, unit: 'R$', separator: ',', delimiter: '.') : '-' %></td>
                  <td><span class="badge bg-light text-dark"><%= movement.source_label %></span></td>
                  <td><%= movement.document_number || '-' %></td>
                  <td>
                    <% if movement.supplier_name.present? %>
                      <%= movement.supplier_name %>
                      <% if movement.supplier_cnpj.present? %>
                        <br><small class="text-muted"><%= movement.supplier_cnpj %></small>
                      <% end %>
                    <% else %>
                      -
                    <% end %>
                  </td>
                  <td><%= movement.user&.name %></td>
                  <td><%= movement.reason || '-' %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        <div class="mt-3">
          <%= paginate @movements %>
        </div>
      <% else %>
        <p class="text-muted mb-0 text-center py-4">Nenhuma movimentação registrada para este item.</p>
      <% end %>
    </div>
  </div>
</div>
