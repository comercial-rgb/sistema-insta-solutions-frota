<%
breadcrumbs = [
  {active: false, href: root_path, text: t('menu.initial_page')},
  {active: false, href: stock_items_path, text: 'Estoque'},
  {active: false, href: new_import_xml_stock_items_path, text: t('stock.import.title')},
  {active: true, href: '#', text: 'Pré-visualização'},
]
%>

<div class="container-fluid">
  <%= render 'common_pages/breadcrumb', links: breadcrumbs %>

  <div class="row mb-3">
    <div class="col-12">
      <h4 class="mb-0"><i class="bi bi-file-earmark-check me-2"></i>Pré-visualização da Importação</h4>
    </div>
  </div>

  <div class="alert alert-warning mb-4" role="alert">
    <i class="bi bi-exclamation-triangle me-2"></i>
    <strong>Revise os itens abaixo antes de confirmar.</strong> Você pode definir o estoque mínimo de cada item e vinculá-lo a um produto pai (variação).
  </div>

  <% if @preview[:supplier_name].present? %>
  <div class="card mb-4 border-info">
    <div class="card-body py-2">
      <small class="text-muted">
        <strong>Fornecedor:</strong> <%= @preview[:supplier_name] %>
        <% if @preview[:supplier_cnpj].present? %> (CNPJ: <%= @preview[:supplier_cnpj] %>)<% end %>
        <% if @preview[:document_number].present? %> &nbsp;|&nbsp; <strong>NF nº:</strong> <%= @preview[:document_number] %><% end %>
      </small>
    </div>
  </div>
  <% end %>

  <%= form_tag confirm_import_xml_stock_items_path do %>
    <div class="card shadow-sm">
      <div class="card-header bg-primary text-white">
        <i class="bi bi-list-check me-2"></i><%= @preview[:items].count %> <%= 'item'.pluralize(@preview[:items].count) %> encontrado<%= 's' if @preview[:items].count != 1 %>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-sm table-bordered mb-0">
            <thead class="table-light">
              <tr>
                <th>Nome</th>
                <th>Código</th>
                <th>Qtd</th>
                <th>Preço Unit.</th>
                <th>Situação</th>
                <th style="min-width:120px;">Estoque Mínimo</th>
                <th style="min-width:200px;">Vincular ao Produto Pai</th>
              </tr>
            </thead>
            <tbody>
              <% @preview[:items].each_with_index do |item, idx| %>
              <tr class="<%= item[:existing_id].present? ? 'table-warning' : '' %>">
                <td>
                  <strong><%= item[:name] %></strong>
                  <% if item[:brand].present? %><br><small class="text-muted"><%= item[:brand] %></small><% end %>
                </td>
                <td><small><%= item[:code] %></small></td>
                <td><%= item[:quantity] %> <%= item[:unit_measure] %></td>
                <td><%= number_to_currency(item[:unit_price], unit: 'R$ ') %></td>
                <td>
                  <% if item[:existing_id].present? %>
                    <span class="badge bg-warning text-dark">Atualizar</span>
                    <br><small class="text-muted">Já existe: <%= item[:existing_name] %></small>
                  <% else %>
                    <span class="badge bg-success">Novo</span>
                  <% end %>
                </td>
                <td>
                  <input type="number"
                    name="items[<%= idx %>][minimum_quantity]"
                    value="<%= item[:minimum_quantity].to_f > 0 ? item[:minimum_quantity] : '' %>"
                    class="form-control form-control-sm"
                    min="0" step="0.01"
                    placeholder="0">
                  <% # Hidden fields to carry item data %>
                  <input type="hidden" name="items[<%= idx %>][name]" value="<%= item[:name] %>">
                  <input type="hidden" name="items[<%= idx %>][code]" value="<%= item[:code] %>">
                  <input type="hidden" name="items[<%= idx %>][quantity]" value="<%= item[:quantity] %>">
                  <input type="hidden" name="items[<%= idx %>][unit_price]" value="<%= item[:unit_price] %>">
                  <input type="hidden" name="items[<%= idx %>][unit_measure]" value="<%= item[:unit_measure] %>">
                  <input type="hidden" name="items[<%= idx %>][brand]" value="<%= item[:brand] %>">
                  <input type="hidden" name="items[<%= idx %>][ncm]" value="<%= item[:ncm] %>">
                </td>
                <td>
                  <select name="items[<%= idx %>][parent_stock_item_id]" class="form-select form-select-sm">
                    <option value="">— Nenhum —</option>
                    <% @available_parents.each do |parent| %>
                      <option value="<%= parent.id %>"><%= parent.name %> (<%= parent.code %>)</option>
                    <% end %>
                  </select>
                </td>
              </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
      <div class="card-footer d-flex gap-2">
        <%= submit_tag 'Confirmar Importação', class: 'btn btn-success', data: { confirm: "Confirmar a importação de #{@preview[:items].count} itens?" } %>
        <%= link_to 'Cancelar', new_import_xml_stock_items_path, class: 'btn btn-secondary' %>
      </div>
    </div>
  <% end %>
</div>
