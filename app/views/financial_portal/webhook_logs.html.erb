<%
breadcrumbs = [
  {active: false, href: root_path, text: t('menu.initial_page')},
  {active: false, href: financial_portal_path, text: 'Portal Financeiro'},
  {active: true, href: '#', text: 'Webhook Logs'},
]
%>

<div class="container-fluid">
  <%= render 'common_pages/breadcrumb', links: breadcrumbs %>

  <!-- Header -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="card border-0 shadow-sm" style="background: linear-gradient(135deg, #b71c1c 0%, #c62828 50%, #e53935 100%);">
        <div class="card-body text-white p-4">
          <div class="row align-items-center">
            <div class="col-md-8">
              <h3 class="mb-2">
                <i class="bi bi-arrow-repeat me-2"></i> Gerenciamento de Webhooks
              </h3>
              <p class="mb-0 opacity-75">
                Acompanhe e reprocesse as OS que falharam no envio ao Portal Financeiro.
                O sistema tenta enviar automaticamente 3 vezes. Aqui você pode reenviar manualmente as que falharam.
              </p>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
              <a href="<%= financial_portal_path %>" class="btn btn-outline-light">
                <i class="bi bi-arrow-left me-1"></i> Voltar ao Portal
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Contadores -->
  <div class="row mb-4">
    <div class="col-md-4 mb-3">
      <a href="<%= financial_portal_webhook_logs_path(filter: 'failed') %>" class="text-decoration-none">
        <div class="card shadow-sm border-danger h-100 <%= @filter == 'failed' ? 'bg-danger text-white' : '' %>">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <h6 class="<%= @filter == 'failed' ? 'text-white' : 'text-muted' %> mb-1">Com Falha</h6>
                <h3 class="mb-0 <%= @filter == 'failed' ? 'text-white' : 'text-danger' %>"><%= @failed_count %></h3>
              </div>
              <i class="bi bi-x-circle fs-1 <%= @filter == 'failed' ? 'text-white opacity-75' : 'text-danger' %>"></i>
            </div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-md-4 mb-3">
      <a href="<%= financial_portal_webhook_logs_path(filter: 'pending') %>" class="text-decoration-none">
        <div class="card shadow-sm border-warning h-100 <%= @filter == 'pending' ? 'bg-warning' : '' %>">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <h6 class="text-muted mb-1">Pendentes</h6>
                <h3 class="mb-0 text-warning"><%= @pending_count %></h3>
              </div>
              <i class="bi bi-clock-history fs-1 text-warning"></i>
            </div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-md-4 mb-3">
      <a href="<%= financial_portal_webhook_logs_path(filter: 'success') %>" class="text-decoration-none">
        <div class="card shadow-sm border-success h-100 <%= @filter == 'success' ? 'bg-success text-white' : '' %>">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <h6 class="<%= @filter == 'success' ? 'text-white' : 'text-muted' %> mb-1">Enviadas</h6>
                <h3 class="mb-0 <%= @filter == 'success' ? 'text-white' : 'text-success' %>"><%= @success_count %></h3>
              </div>
              <i class="bi bi-check-circle fs-1 <%= @filter == 'success' ? 'text-white opacity-75' : 'text-success' %>"></i>
            </div>
          </div>
        </div>
      </a>
    </div>
  </div>

  <!-- Ação em massa -->
  <% if @filter == 'failed' && @failed_count > 0 %>
    <div class="row mb-3">
      <div class="col-12">
        <div class="alert alert-danger border-0 shadow-sm d-flex justify-content-between align-items-center" role="alert">
          <div>
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong><%= @failed_count %></strong> OS com falha no envio ao Portal Financeiro.
          </div>
          <%= link_to financial_portal_webhook_resend_all_path, method: :post,
              class: 'btn btn-danger btn-sm',
              data: { confirm: "Tem certeza que deseja reenviar todas as #{@failed_count} OS com falha?" } do %>
            <i class="bi bi-arrow-repeat me-1"></i> Reenviar Todas
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Filtros -->
  <div class="row mb-3">
    <div class="col-12">
      <div class="btn-group" role="group">
        <a href="<%= financial_portal_webhook_logs_path(filter: 'failed') %>"
           class="btn btn-sm <%= @filter == 'failed' ? 'btn-danger' : 'btn-outline-danger' %>">
          <i class="bi bi-x-circle me-1"></i> Falhas <span class="badge bg-white text-danger"><%= @failed_count %></span>
        </a>
        <a href="<%= financial_portal_webhook_logs_path(filter: 'pending') %>"
           class="btn btn-sm <%= @filter == 'pending' ? 'btn-warning' : 'btn-outline-warning' %>">
          <i class="bi bi-clock me-1"></i> Pendentes <span class="badge bg-white text-warning"><%= @pending_count %></span>
        </a>
        <a href="<%= financial_portal_webhook_logs_path(filter: 'success') %>"
           class="btn btn-sm <%= @filter == 'success' ? 'btn-success' : 'btn-outline-success' %>">
          <i class="bi bi-check-circle me-1"></i> Enviadas <span class="badge bg-white text-success"><%= @success_count %></span>
        </a>
        <a href="<%= financial_portal_webhook_logs_path(filter: 'all') %>"
           class="btn btn-sm <%= @filter == 'all' ? 'btn-secondary' : 'btn-outline-secondary' %>">
          <i class="bi bi-list me-1"></i> Todas
        </a>
      </div>
    </div>
  </div>

  <!-- Tabela -->
  <div class="card shadow-sm mb-4">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
      <span><i class="bi bi-table me-2"></i> Webhook Logs</span>
      <span class="badge bg-light text-dark"><%= @webhook_logs.total_count %> registros</span>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>OS</th>
              <th>Cliente</th>
              <th>Fornecedor</th>
              <th>Status OS</th>
              <th>Webhook</th>
              <th>Tentativas</th>
              <th>Último Erro</th>
              <th>Última Tentativa</th>
              <th class="text-center">Ações</th>
            </tr>
          </thead>
          <tbody>
            <% if @webhook_logs.empty? %>
              <tr>
                <td colspan="9" class="text-center text-muted py-4">
                  <i class="bi bi-check-circle fs-1 d-block mb-2 text-success"></i>
                  Nenhum registro encontrado para este filtro.
                </td>
              </tr>
            <% end %>
            <% @webhook_logs.each do |log| %>
              <% os = log.order_service %>
              <% next unless os %>
              <% 
                approved = os.order_service_proposals.detect { |p| 
                  [3, 4, 5, 6, 7].include?(p.order_service_proposal_status_id) && !p.is_complement 
                }
                provider = approved&.provider
              %>
              <tr>
                <td>
                  <a href="<%= order_service_path(os) %>" class="fw-bold text-decoration-none">
                    <%= os.code %>
                  </a>
                </td>
                <td><%= os.client&.fantasy_name || os.client&.social_name || 'N/A' %></td>
                <td><%= provider&.fantasy_name || provider&.social_name || 'N/A' %></td>
                <td>
                  <%
                    os_badge = case os.order_service_status_id
                               when 5, 7 then 'bg-primary'
                               when 6 then 'bg-warning text-dark'
                               when 9 then 'bg-dark'
                               else 'bg-secondary'
                               end
                  %>
                  <span class="badge <%= os_badge %>"><%= os.order_service_status&.name || "Status #{os.order_service_status_id}" %></span>
                </td>
                <td>
                  <span class="badge <%= log.status_badge_class %>">
                    <i class="bi bi-<%= log.success? ? 'check-circle' : log.failed? ? 'x-circle' : 'clock' %> me-1"></i>
                    <%= log.status_label %>
                  </span>
                </td>
                <td class="text-center"><%= log.attempts %></td>
                <td>
                  <% if log.last_error.present? %>
                    <span class="text-danger small" title="<%= log.last_error %>" data-bs-toggle="tooltip">
                      <%= truncate(log.last_error, length: 60) %>
                    </span>
                  <% else %>
                    <span class="text-muted">-</span>
                  <% end %>
                </td>
                <td>
                  <% if log.last_attempt_at %>
                    <small class="text-muted"><%= log.last_attempt_at.strftime('%d/%m/%Y %H:%M') %></small>
                  <% else %>
                    <span class="text-muted">-</span>
                  <% end %>
                </td>
                <td class="text-center">
                  <% unless log.success? %>
                    <%= link_to financial_portal_webhook_resend_path(log, filter: @filter), method: :post,
                        class: 'btn btn-sm btn-outline-primary',
                        title: 'Reenviar webhook',
                        data: { confirm: "Reenviar OS #{os.code} ao Portal Financeiro?" } do %>
                      <i class="bi bi-arrow-repeat"></i> Reenviar
                    <% end %>
                  <% else %>
                    <span class="text-success small">
                      <i class="bi bi-check-lg"></i> OK
                      <% if log.succeeded_at %>
                        <br><small><%= log.succeeded_at.strftime('%d/%m/%Y') %></small>
                      <% end %>
                    </span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
    <% if @webhook_logs.total_pages > 1 %>
      <div class="card-footer">
        <%= paginate @webhook_logs %>
      </div>
    <% end %>
  </div>
</div>

<script>
  // Ativa tooltips do Bootstrap
  document.addEventListener('DOMContentLoaded', function() {
    var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
    tooltipTriggerList.forEach(function(el) {
      new bootstrap.Tooltip(el);
    });
  });
</script>
